//#region --- 6. Initialisierung und Setup ---
function init() {
  // Verhindert mehrfache Ausführung - init() soll nur einmal pro Seitenladung laufen
  if (initHasRun) {
    return;
  }
  initHasRun = true;

  if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] 🎬 Script init() started`);

  if (DEBUG.initialization) {
    console.log("[MDM] 🚀 init() called");
  }

  // ===== 1. Grundeinstellungen und gespeicherte Daten laden =====
  // loadSettings() lädt ALLE Daten: excludeWords, whitelistWords, merchants, maxPrice, hideColdDeals, hiddenDeals, etc.
  loadSettings();

  // --- Kürzlich versteckte Deals ---
  recentHiddenDeals = GM_getValue("recentHiddenDeals", []);

  // --- Sortierung merken ---
  processSucheinstellungen();

  // URL-Änderungen überwachen (für Single-Page-App Navigation)
  let lastUrl = window.location.href;
  const urlObserver = new MutationObserver(() => {
    const currentUrl = window.location.href;
    if (currentUrl !== lastUrl) {
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] URL geändert von', lastUrl, 'zu', currentUrl);
      }
      lastUrl = currentUrl;
      // Kurze Verzögerung damit die Seite laden kann
      setTimeout(() => {
        processSucheinstellungen();
        setupSearchFormHandlers(); // Auch Formulare neu einrichten
      }, 300);
    }
  });
  urlObserver.observe(document.body, { childList: true, subtree: true });

  // Auch bei popstate (Zurück/Vor-Navigation) aufrufen
  window.addEventListener('popstate', () => {
    if (DEBUG.rememberSort) {
      console.log('[MDM RememberSort] popstate Event erkannt');
    }
    setTimeout(() => {
      processSucheinstellungen();
      setupSearchFormHandlers(); // Auch Formulare neu einrichten
    }, 300);
  });

  // MutationObserver für neue Suchformulare (erkennt dynamisch hinzugefügte Formulare)
  const formObserver = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
        for (const node of mutation.addedNodes) {
          // Prüfe ob der Node selbst ein Formular ist
          if (node.nodeType === 1) { // ELEMENT_NODE
            if (node.tagName === 'FORM' && node.action && node.action.includes('/search')) {
              if (DEBUG.rememberSort) {
                console.log('[MDM RememberSort] 🆕 Neues Suchformular im DOM erkannt:', node);
              }
              setupSearchFormHandlers();
              break;
            }
            // Prüfe ob der Node Formulare enthält
            const forms = node.querySelectorAll?.('form[action*="/search"]');
            if (forms && forms.length > 0) {
              if (DEBUG.rememberSort) {
                console.log('[MDM RememberSort] 🆕 Neue Suchformulare im DOM erkannt:', forms.length);
              }
              setupSearchFormHandlers();
              break;
            }
          }
        }
      }
    }
  });
  formObserver.observe(document.body, { childList: true, subtree: true });
  if (DEBUG.rememberSort) {
    console.log('[MDM RememberSort] 👁️ MutationObserver für Suchformulare aktiv');
  }

  // Initial Formulare einrichten (falls bereits im DOM)
  setTimeout(() => {
    if (DEBUG.rememberSort) {
      console.log('[MDM RememberSort] 🔍 Initiale Suche nach Formularen...');
    }
    setupSearchFormHandlers();
  }, 500);

  // ===== 2. Feature-Flags und UI-Status =====

  // --- Händlernamen ---
  window.hideMatchingMerchantNames = hideMatchingMerchantNames;

  // ===== 3. Keyboard-Handler =====
  // ESC-Taste schließt mydealz Manager UIs schrittweise
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      // Prüfe ob ein Sub-UI offen ist
      if (activeSubUI) {
        closeActiveSubUI();
        e.preventDefault();
        e.stopPropagation();
      } else if (isSettingsOpen) {
        // Main-UI schließen wenn kein Sub-UI mehr offen
        cleanup();
        e.preventDefault();
        e.stopPropagation();
      }
    }
  });

  // ===== 5. System-Initialisierung =====

  // --- UI ---
  initializeUI();

  if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] 📡 Calling initObserver()`);
  initObserver();
  if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] ✅ initObserver() complete`);

  // --- Scroll Handling (nur einmal global initialisieren) ---
  setupScrollHandling();

  // WICHTIG: Initiales Filtern nach Skript-Start mit forceRun=true
  // Dadurch wird der Early Exit umgangen und ALLE Deals werden garantiert gefiltert
  // auch wenn Vue3 noch asynchron rendert oder Deals verzögert geladen werden
  setTimeout(() => {
    processArticles(true);
  }, 500);

  // ===== 6. Detail-Seite Highlighting =====
  // Zeige Badge auf Detail-Seiten wenn Deal gefiltert würde
  setTimeout(() => {
    checkAndHighlightFilteredDealOnDetailPage();
  }, 300);
}

