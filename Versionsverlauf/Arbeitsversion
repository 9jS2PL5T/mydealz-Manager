// Text Normalisierung Map für Sonderzeichen
const CHAR_NORMALIZATION_MAP = {
  ä: "a",
  á: "a",
  à: "a",
  â: "a",
  ã: "a",
  ö: "o",
  ó: "o",
  ò: "o",
  ô: "o",
  õ: "o",
  ü: "u",
  ú: "u",
  ù: "u",
  û: "u",
  é: "e",
  è: "e",
