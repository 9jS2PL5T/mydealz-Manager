    });

    const username = userInfo.displayName || "";
    const normalizedUsername = username.toLowerCase();

    if (DEBUG.hoverButtons) {
      console.log(`[MDM HoverButtons] Deal ${dealId}:`, {
        username,
        normalizedUsername,
        alreadyBlocked: blockedUsersSet.has(normalizedUsername),
      });
