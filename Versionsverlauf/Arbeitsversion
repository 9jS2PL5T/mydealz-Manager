      listSortStates.words.mode = mode;
      listSortStates.words.ascending = ascending;
      document.removeEventListener("click", closeWordsDropdown);
      // UI neu aufbauen ohne activeSubUI zu ändern
      const oldDiv = wordsListDiv;
      if (oldDiv && oldDiv.parentNode) {
        oldDiv.parentNode.removeChild(oldDiv);
      }
      createExcludeWordsUI();
    });
    // Hover-Effekt
    item.addEventListener("mouseenter", () => {
      item.style.background = colors.itemBg;
    });
    item.addEventListener("mouseleave", () => {
      item.style.background = "none";
    });
  });

  // Add search functionality
  const searchInput = document.getElementById("wordSearch");
  const clearBtn = document.getElementById("wordSearchClear");
  const totalCount = loadExcludeWords().length; // Cache total count
  const wordItems = document.querySelectorAll(".word-item"); // Cache DOM query
  const itemsArray = Array.from(wordItems); // Convert to array for reuse

  function updateWordClearVisibility() {
    clearBtn.style.display = searchInput.value ? "block" : "none";
  }

  searchInput.addEventListener("input", (e) => {
    updateWordClearVisibility();
    const searchTerm = e.target.value;
    let visibleCount = 0;

    // Nutze gecachte Items statt neuer QueryAll bei jedem Input
    itemsArray.forEach((item) => {
      const span = item.querySelector("span");
      const isVisible = span && matchesSearchTerm(span.textContent, searchTerm);
      item.style.display = isVisible ? "flex" : "none";
      if (isVisible) visibleCount++;
    });

    // Update heading counter (nur wenn sich Sichtbarkeit ändert)
    const heading = wordsListDiv.querySelector("h4");
    if (heading) {
      heading.textContent = searchTerm
        ? `Ausgeblendete Wörter (${visibleCount}/${totalCount})`
        : `Ausgeblendete Wörter (${totalCount})`;
    }
  });

  clearBtn.addEventListener("click", () => {
    searchInput.value = "";
    updateWordClearVisibility();
    searchInput.dispatchEvent(new Event("input"));
    searchInput.focus();
  });
  updateWordClearVisibility();

  // Alle Wörter entfernen Button
  document
    .getElementById("clearWordsListButton")
    .addEventListener("click", () => {
      if (
        confirm("Möchten Sie wirklich alle Wörter aus der Liste entfernen?")
      ) {
        saveExcludeWords([]);
        wordAddedAt = {};
        GM_setValue("wordAddedAt", wordAddedAt);
        document.getElementById("wordsList").innerHTML = "";
        excludeWords = [];
        processArticles();

        // Immediately update counter in heading
        const heading = wordsListDiv.querySelector("h4");
        if (heading) {
          heading.textContent = "Ausgeblendete Wörter (0)";
        }
      }
    });

  // Delegated handlers for delete/edit/timestamp to avoid per-item loops
  const wordsContainer = document.getElementById("wordsList");
  if (wordsContainer) {
    wordsContainer.addEventListener("click", (e) => {
      e.stopPropagation();
      const deleteBtn = e.target.closest(".delete-word");
      if (deleteBtn) {
        handleWordDelete(e);
        return;
      }

      const wordText = e.target.closest(".word-text");
      if (wordText) {
        // Wenn bereits editierbar, nicht erneut aktivieren (verhindert ständiges Re-Select)
        if (wordText.getAttribute('contenteditable') === 'true') return;
        const word = wordText.getAttribute("data-word");

        if (IS_TOUCH_DEVICE) {
          // Tooltip toggeln
          const tooltip = wordText.nextElementSibling;
          if (tooltip && tooltip.classList.contains("timestamp-tooltip")) {
            const computedDisplay = window.getComputedStyle(tooltip).display;
            const isVisible = computedDisplay === "block";
            document
              .querySelectorAll(".timestamp-tooltip")
              .forEach((t) => {
                t.style.display = "none";
              });
            if (!isVisible) {
              const item = wordText.closest(".word-item");
              const itemRect = item.getBoundingClientRect();
              const container = document.getElementById("wordsList");
              const containerRect = container.getBoundingClientRect();
              const tooltipHeight = 30; // Geschätzte Höhe
              const spaceAbove = itemRect.top - containerRect.top;
              const spaceBelow = containerRect.bottom - itemRect.bottom;
              if (spaceAbove < tooltipHeight && spaceBelow > tooltipHeight) {
                tooltip.style.bottom = "auto";
                tooltip.style.top = "100%";
                tooltip.style.marginTop = "4px";
                tooltip.style.marginBottom = "0";
              } else {
                tooltip.style.top = "auto";
                tooltip.style.bottom = "100%";
                tooltip.style.marginBottom = "4px";
                tooltip.style.marginTop = "0";
              }
              tooltip.style.display = "block";
            }
          }
        } else {
          makeEntryEditable(wordText, "word", word, currentWords, {
            addClick: false,
            activateImmediately: true,
          });
        }
      }
    });

    if (IS_TOUCH_DEVICE) {
      let longPressTimer;
      wordsContainer.addEventListener('touchstart', (e) => {
        const wordText = e.target.closest('.word-text');
        if (!wordText) return;
        longPressTimer = setTimeout(() => {
          if (wordText.getAttribute('contenteditable') === 'true') return;
          const word = wordText.getAttribute('data-word');
          makeEntryEditable(wordText, 'word', word, currentWords, {
            addClick: false,
            activateImmediately: true,
          });
        }, 600);
      });
      ['touchend','touchmove','touchcancel'].forEach(evt => {
        wordsContainer.addEventListener(evt, () => clearTimeout(longPressTimer));
      });
    }
  }

  // Update close button handlers in createExcludeWordsUI
  document
    .getElementById("closeWordsListButton")
    .addEventListener("click", (e) => {
      e.stopPropagation(); // Prevent event bubbling
      closeActiveSubUI();
    });
  // Before adding to DOM
  document.body.appendChild(wordsListDiv);

  setupClickOutsideHandler();
}

