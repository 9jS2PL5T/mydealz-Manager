function tryInitializeModularDebug() {
  if (debugModuleRuntime) return true;

  const globalScope = typeof unsafeWindow !== "undefined" ? unsafeWindow : window;
  const debugModules = globalScope?.MDMDebugModules || window.MDMDebugModules;

  if (
    !debugModules ||
    typeof debugModules.initializeDebugModule !== "function" ||
    typeof debugModules.createTampermonkeyBridge !== "function"
  ) {
    return false;
  }

  try {
    const bridge = debugModules.createTampermonkeyBridge();
    debugModuleRuntime = debugModules.initializeDebugModule({
      showDebugMenu: SHOW_DEBUG_MENU,
      ...bridge,
    });

    if (debugModuleRuntime?.debugConfig) {
      Object.assign(DEBUG, debugModuleRuntime.debugConfig);
    }

    if (DEBUG.initialization) {
      console.log("[MDM Debug] Modulares Debug-System aktiviert");
    }

    return true;
  } catch (error) {
    console.warn("[MDM Debug] Modulares Debug-System konnte nicht initialisiert werden:", error);
    return false;
  }
}

function initializeDebugSystem() {
  setTimeout(() => {
    if (!tryInitializeModularDebug() && DEBUG.initialization) {
      console.warn("[MDM Debug] Modulares Debug-Bundle nicht gefunden - Debug bleibt auf Default-Werten");
    }
  }, 0);
}

