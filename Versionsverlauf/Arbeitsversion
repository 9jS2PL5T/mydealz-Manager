      border: 1px solid ${getThemeColors().buttonBorder};
      background: ${getThemeColors().buttonBg};
      color: ${getThemeColors().text};
      cursor: pointer;
      font-size: 11px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.12s ease;
      z-index: 1000;
    `;

    let hideTimer = null;
    const showButton = () => {
      clearTimeout(hideTimer);
      blockButton.style.opacity = "1";
      blockButton.style.pointerEvents = "auto";
    };

    const queueHide = () => {
      clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        blockButton.style.opacity = "0";
        blockButton.style.pointerEvents = "none";
      }, 250);
    };

    // Hover-Bereich: Gesamter Container (falls vorhanden)
    const hoverContainer = merchantLink.parentElement || merchantLink;
    hoverContainer.style.position = "relative";
    hoverContainer.style.overflow = "visible";
    hoverContainer.addEventListener("mouseenter", showButton);
    hoverContainer.addEventListener("mouseleave", queueHide);
    blockButton.addEventListener("mouseenter", showButton);
    blockButton.addEventListener("mouseleave", queueHide);

    blockButton.addEventListener("click", async (e) => {
      e.preventDefault();
      e.stopPropagation();

      const merchantConfirmed = await confirmBlockAction(
        `Möchtest du wirklich alle Deals von "${merchantName}" ausblenden?`
      );
      if (!merchantConfirmed) {
        return;
      }

      const currentMerchants = loadExcludeMerchants();
      if (!currentMerchants.some((m) => m.id === merchantId)) {
        currentMerchants.unshift({ id: merchantId, name: merchantName });
        saveExcludeMerchants(currentMerchants);
        processArticles();
      }
    });

    // Button in Container einfügen (absolut positioniert, nimmt keinen Platz weg)
    hoverContainer.appendChild(blockButton);

    if (DEBUG.hoverButtons) {
      console.log(`[MDM HoverButtons] Deal ${dealId} - Merchant button added successfully`);
    }
  });

  if (DEBUG.hoverButtons) {
    console.log("[MDM HoverButtons] Finished merchant buttons:", {
      buttonsAdded: document.querySelectorAll(".mdm-merchant-hover-block-btn").length,
    });
  }
}

function getMerchantButtonText(merchantName) {
  return `Alle Deals von ${merchantName}`;
}

function addMerchantPageHideButton() {
  const urlParams = new URLSearchParams(window.location.search);
  const merchantId = urlParams.get("merchant-id");
  const merchantBanner = document.querySelector(MERCHANT_PAGE_SELECTOR);
  const merchantName = document
    .querySelector(".merchant-banner__title")
    ?.textContent.trim();

  if (!merchantId || !merchantBanner || !merchantName) return;

  const hideButtonContainer = document.createElement("div");
  hideButtonContainer.style.cssText = `
        display: inline-flex;
        align-items: center;
        margin-left: 10px;
    `;

  const hideButton = document.createElement("button");
  hideButton.style.cssText = `
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        background: #f0f0f0;
        border: 1px solid #ccc;
        border-radius: 3px;
        cursor: pointer;
        font-size: 14px;
    `;

  const buttonText = getMerchantButtonText(merchantName);
  hideButton.innerHTML = `
        <span style="display: inline-flex; align-items: center; gap: 8px; white-space: nowrap;">
            <i class="fas fa-store-slash"></i>
            <span>${buttonText}</span>
        </span>
    `;
  hideButton.title = `${buttonText} ausblenden`;

  hideButton.addEventListener("click", async () => {
    const merchantConfirmed = await confirmBlockAction(
      `Möchtest du wirklich alle Deals von "${merchantName}" ausblenden?`
    );
    if (!merchantConfirmed) {
      return;
    }

    const merchantsData = loadExcludeMerchants();
    if (!merchantsData.some((m) => m.id === merchantId)) {
      merchantsData.unshift({ id: merchantId, name: merchantName });
      saveExcludeMerchants(merchantsData);
      processArticles();
    }
  });

  hideButtonContainer.appendChild(hideButton);
  merchantBanner.appendChild(hideButtonContainer);
}

