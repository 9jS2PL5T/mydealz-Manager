// Flexible Suche: Prüft ob alle Suchterm-Wörter im Text vorkommen (nicht nur substring match)
function matchesSearchTerm(itemText, searchTerm) {
  if (!searchTerm || searchTerm.length === 0) return true;
  const itemLower = itemText.toLowerCase();
  const terms = searchTerm.toLowerCase().split(/\s+/).filter(t => t.length > 0);
  return terms.every(term => itemLower.includes(term));
