// Universelle Funktion zum Aktivieren des Edit-Modus für Listeneinträge
function makeEntryEditable(editableElement, listType, originalValue, allValues, options = {}) {
  const colors = getThemeColors();
  const { addClick = true, activateImmediately = false } = options;

  // Edit-Modus aktivieren
  const activateEditMode = () => {
    editableElement.setAttribute('contenteditable', 'true');
    editableElement.style.backgroundColor = colors.inputBg;
    editableElement.style.border = `2px solid ${colors.linkColor || '#007bff'}`;
    editableElement.style.padding = '4px 6px';
    editableElement.style.borderRadius = '3px';
    editableElement.style.cursor = 'text';
    editableElement.focus();

    // Text selektieren
    const selection = window.getSelection();
    const range = document.createRange();
    range.selectNodeContents(editableElement);
    selection.removeAllRanges();
    selection.addRange(range);
  };

  // Edit-Modus beenden und speichern
  const saveEdit = async () => {
    const newValue = editableElement.textContent.trim();

    if (!newValue) {
      // Leer = Abbruch
      editableElement.setAttribute('contenteditable', 'false');
      editableElement.textContent = originalValue;
      editableElement.style.backgroundColor = 'transparent';
      editableElement.style.border = 'none';
      return;
    }

    if (newValue === originalValue) {
      // Keine Änderung
      editableElement.setAttribute('contenteditable', 'false');
      editableElement.style.backgroundColor = 'transparent';
      editableElement.style.border = 'none';
      return;
    }

    // Duplikat-Prüfung (normalisiert vergleichen)
    const normalizedNew = normalizeForSearch(newValue);
    const normalizedExisting = allValues
      .filter(v => v !== originalValue)
      .map(v => normalizeForSearch(v));

    if (normalizedExisting.includes(normalizedNew)) {
      alert(`"${newValue}" existiert bereits in dieser Liste!`);
      editableElement.textContent = originalValue;
      editableElement.setAttribute('contenteditable', 'false');
      editableElement.style.backgroundColor = 'transparent';
      editableElement.style.border = 'none';
      return;
    }

    // Speichern basierend auf Typ
    try {
      // Speichere ORIGINAL Timestamps VOR dem Umbenennen (um sie später wiederherzustellen)
      const originalTimestamps = {};

      if (listType === 'word') {
        const normalizedOrig = normalizeForSearch(originalValue);
        if (wordAddedAt[normalizedOrig]) {
          originalTimestamps.word = wordAddedAt[normalizedOrig];
        }

        const words = loadExcludeWords();
        const index = words.indexOf(originalValue);
        if (index >= 0) {
          words[index] = newValue;
          saveExcludeWords(words, false); // false = nicht neu createMissing
        }

        // Stelle Timestamp auf neuem Key wieder her
        const normalizedNew = normalizeForSearch(newValue);
        if (originalTimestamps.word) {
          wordAddedAt[normalizedNew] = originalTimestamps.word;
          GM_setValue("wordAddedAt", wordAddedAt);
        }
      } else if (listType === 'whitelist') {
        const normalizedOrig = normalizeForSearch(originalValue);
        if (whitelistAddedAt[normalizedOrig]) {
          originalTimestamps.whitelist = whitelistAddedAt[normalizedOrig];
        }

        const words = loadWhitelistWords();
        const index = words.indexOf(originalValue);
        if (index >= 0) {
          words[index] = newValue;
          saveWhitelistWords(words, false);
        }

        const normalizedNew = normalizeForSearch(newValue);
        if (originalTimestamps.whitelist) {
          whitelistAddedAt[normalizedNew] = originalTimestamps.whitelist;
          GM_setValue("whitelistAddedAt", whitelistAddedAt);
        }
      } else if (listType === 'merchant') {
        const merchants = loadExcludeMerchants();
        const merchant = merchants.find(m => m.name === originalValue);
        if (merchant) {
          const originalId = String(merchant.id);
          if (merchantAddedAt[originalId]) {
            originalTimestamps.merchant = merchantAddedAt[originalId];
          }

          merchant.name = newValue;
          saveExcludeMerchants(merchants, false);

          if (originalTimestamps.merchant) {
            merchantAddedAt[originalId] = originalTimestamps.merchant;
            GM_setValue("merchantAddedAt", merchantAddedAt);
          }
        }
      } else if (listType === 'user') {
        const usernameLower = originalValue.toLowerCase();
        if (userAddedAt[usernameLower]) {
          originalTimestamps.user = userAddedAt[usernameLower];
        }

        const blockedUsersData = GM_getValue("blockedUsers", {});
        const users = Object.keys(blockedUsersData);
        const index = users.indexOf(usernameLower);
        if (index >= 0) {
          const reason = blockedUsersData[users[index]];
          delete blockedUsersData[users[index]];
          blockedUsersData[newValue.toLowerCase()] = reason;
          GM_setValue("blockedUsers", blockedUsersData);
        }

        if (originalTimestamps.user) {
          userAddedAt[newValue.toLowerCase()] = originalTimestamps.user;
          GM_setValue("userAddedAt", userAddedAt);
        }
      }

      editableElement.setAttribute('contenteditable', 'false');
      editableElement.textContent = newValue;
      editableElement.style.backgroundColor = 'transparent';
      editableElement.style.border = 'none';

      // Speichere aktuellen Suchterm vor UI-Rebuild
      const searchFieldId = {
        'word': 'wordSearch',
        'whitelist': 'whitelistSearch',
        'merchant': 'merchantSearch',
        'user': 'userSearch'
      }[listType];

      const searchField = document.getElementById(searchFieldId);
      if (searchField) {
        searchStates[{
          'word': 'words',
          'whitelist': 'whitelist',
          'merchant': 'merchants',
          'user': 'users'
        }[listType]] = searchField.value;
      }

      // Update entsprechende UI
      if (listType === 'word') {
        createExcludeWordsUI();
      } else if (listType === 'whitelist') {
        createWhitelistUI();
      } else if (listType === 'merchant') {
        createMerchantListUI();
      } else if (listType === 'user') {
        createBlockedUsersUI();
      }

      // Stelle Suchterm nach UI-Rebuild wieder her
      setTimeout(() => {
        const restoreField = document.getElementById(searchFieldId);
        const clearBtnId = {
          'word': 'wordSearchClear',
          'whitelist': 'whitelistSearchClear',
          'merchant': 'merchantSearchClear',
          'user': 'userSearchClear'
        }[listType];
        const clearBtn = document.getElementById(clearBtnId);

        const stateKey = {
          'word': 'words',
          'whitelist': 'whitelist',
          'merchant': 'merchants',
          'user': 'users'
        }[listType];

        if (restoreField) {
          // Setze Suchterm
          restoreField.value = searchStates[stateKey] || "";
          // Trigger input event, um die Filterung initial anzuwenden
          // Das ist WICHTIG: Ohne diesen Event werden Items nicht gefiltert
          restoreField.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }, 0);
    } catch (error) {
      console.error(`[MDM Edit] Fehler beim Speichern von ${listType}:`, error);
      alert(`Fehler beim Speichern! Versuchen Sie es später erneut.`);
      editableElement.textContent = originalValue;
      editableElement.setAttribute('contenteditable', 'false');
      editableElement.style.backgroundColor = 'transparent';
      editableElement.style.border = 'none';
    }
  };

  // Event-Handler
  const handleKeyDown = (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      e.stopPropagation();
      saveEdit();
    } else if (e.key === 'Escape') {
      e.preventDefault();
      e.stopPropagation();
      editableElement.textContent = originalValue;
      editableElement.setAttribute('contenteditable', 'false');
      editableElement.style.backgroundColor = 'transparent';
      editableElement.style.border = 'none';
    }
  };

  const handleBlur = () => {
    // Bei iOS/Android wird Blur sofort nach Enter getriggert
    // Kleiner Delay um doppelte Speicherung zu vermeiden
    setTimeout(() => {
      if (editableElement.getAttribute('contenteditable') === 'true') {
        saveEdit();
      }
    }, 100);
  };

  // Click zum Aktivieren (sofern gewünscht)
  if (addClick) {
    editableElement.addEventListener('click', (e) => {
      if (editableElement.getAttribute('contenteditable') !== 'true') {
        e.stopPropagation();
        activateEditMode();
      }
    });

    editableElement.addEventListener('keydown', handleKeyDown);
    editableElement.addEventListener('blur', handleBlur);

    // Auf Touch-Geräten: Double-Tap zum Aktivieren
    if (IS_TOUCH_DEVICE) {
      let lastClickTime = 0;
      editableElement.addEventListener('click', (e) => {
        const now = Date.now();
        if (now - lastClickTime < 300) {
          // Double-Tap erkannt
          e.stopPropagation();
          activateEditMode();
        }
        lastClickTime = now;
      });
    }
  } else {
    // bei delegiertem Aufruf müssen zumindest keydown/blur noch registriert
    editableElement.addEventListener('keydown', handleKeyDown);
    editableElement.addEventListener('blur', handleBlur);
  }

  if (activateImmediately) {
    activateEditMode();
  }
}

