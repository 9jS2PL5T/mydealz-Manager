};

function normalizeForSearch(text) {
  if (!text) return "";

  // Zu Lowercase konvertieren
  let normalized = text.toLowerCase();

  // Non-breaking Spaces und andere unsichtbare Zeichen zu normalen Spaces konvertieren
  // Dies behandelt &nbsp; (\u00A0) und andere Unicode-Leerzeichen
  normalized = normalized.replace(
    /[\u00A0\u202F\u2000-\u200B\u205F\u3000]/g,
    " "
  );

  // Alle Apostroph-Varianten zu normalem Apostroph konvertieren
  // ' (U+2018 Left Single Quotation), ' (U+2019 Right Single Quotation), ` (U+0060 Grave Accent)
  normalized = normalized.replace(/[\u2018\u2019\u0060]/g, "'");

  // Alle Bindestrich-Varianten zu normalem Hyphen konvertieren
  // U+2010 (Hyphen), U+2011 (Nonbreaking Hyphen), U+2012 (Figure Dash), U+2013 (En Dash), U+2014 (Em Dash), U+2015 (Horizontal Bar)
  normalized = normalized.replace(/[\u2010-\u2015]/g, "-");

  // Sonderzeichen normalisieren
  normalized = normalized
    .split("")
    .map((char) => CHAR_NORMALIZATION_MAP[char] || char)
    .join("");

  // Unicode normalisieren (NFD) und dann alle diakritischen Zeichen entfernen
  normalized = normalized.normalize("NFD").replace(/[\u0300-\u036f]/g, "");

  // Mehrfache Leerzeichen zu einem Leerzeichen reduzieren
  normalized = normalized.replace(/\s+/g, " ").trim();

  return normalized;
}

function formatTimestamp(date = new Date()) {
  const pad = (n) => n.toString().padStart(2, "0");
  const day = pad(date.getDate());
  const month = pad(date.getMonth() + 1);
  const year = date.getFullYear();
  const hours = pad(date.getHours());
  const minutes = pad(date.getMinutes());
  return `${day}.${month}.${year} ${hours}:${minutes}`;
}

// Debug-Timestamp mit Millisekunden
function getDebugTimestamp() {
  const now = new Date();
  const pad = (n) => n.toString().padStart(2, "0");
  const pad3 = (n) => n.toString().padStart(3, "0");
  const hours = pad(now.getHours());
  const minutes = pad(now.getMinutes());
  const seconds = pad(now.getSeconds());
  const ms = pad3(now.getMilliseconds());
  return `${hours}:${minutes}:${seconds}.${ms}`;
}

function getDealTemperature(deal) {
  if (!deal) return null;

  const tempElement =
    deal.querySelector(".cept-vote-temp .overflow--wrap-off") ||
    deal.querySelector(".vote-temp .overflow--wrap-off");

  if (!tempElement) return null;

  const temperatureText = tempElement.textContent?.trim() || "";
  const temperatureMatch = temperatureText.match(/([-+]?\d+)°/);
  if (!temperatureMatch) return null;

  const temperature = parseInt(temperatureMatch[1], 10);
  return Number.isNaN(temperature) ? null : temperature;
}

function getOverrideReasonLabel(reason, filterDetails = {}) {
  if (!reason) return "Filter";

  if (reason.startsWith("word-filter")) {
    return filterDetails?.matchedWord
      ? `Wortfilter (${filterDetails.matchedWord})`
      : "Wortfilter";
  }
  if (reason.startsWith("merchant-id:") || reason.startsWith("merchant-name:")) {
    return filterDetails?.merchantName
      ? `Händlerfilter (${filterDetails.merchantName})`
      : "Händlerfilter";
  }
  if (reason.startsWith("blocked-user:")) {
    const username = reason.split(":")[1] || filterDetails?.username;
    return username ? `Benutzerfilter (${username})` : "Benutzerfilter";
  }
  if (reason.startsWith("cold-deal:")) return "Kalte Deals";
  if (reason === "price-exceeded") return "Preisfilter";
  return "Filter";
}

function clearTemperatureOverrideVisuals(deal) {
  if (!deal) return;

  deal.querySelectorAll(".mdm-temp-override-badge").forEach((el) => el.remove());
  deal.querySelectorAll(".mdm-temp-override-temp-highlight").forEach((el) => {
    el.classList.remove("mdm-temp-override-temp-highlight");
  });
  deal.querySelectorAll(".mdm-temp-override-reason-highlight").forEach((el) => {
    el.classList.remove("mdm-temp-override-reason-highlight");
  });

  deal.removeAttribute("data-temp-override");
  deal.removeAttribute("data-temp-override-reason");
}

function applyTemperatureOverrideVisuals(
  deal,
  reason,
  temperature,
  filterDetails = {}
) {
  if (!deal) return;

  clearTemperatureOverrideVisuals(deal);

  const reasonLabel = getOverrideReasonLabel(reason, filterDetails);
  const titleContainer = deal.querySelector(".thread-title") || deal;
  const badge = document.createElement("div");
  badge.className = "mdm-temp-override-badge";
  badge.textContent = `Anzeige wegen Temperatur (${temperature}° >= ${temperatureOverrideThreshold}°) | ${reasonLabel}`;
  titleContainer.appendChild(badge);

  const tempElement =
    deal.querySelector(".cept-vote-temp .overflow--wrap-off") ||
    deal.querySelector(".vote-temp .overflow--wrap-off");
  if (tempElement) {
    tempElement.classList.add("mdm-temp-override-temp-highlight");
  }

  const highlightCandidates = [];
  if (reason.startsWith("word-filter")) {
    highlightCandidates.push(deal.querySelector(".thread-title a"));
  } else if (
    reason.startsWith("merchant-id:") ||
    reason.startsWith("merchant-name:")
  ) {
    highlightCandidates.push(deal.querySelector('a[data-t="merchantLink"]'));
  } else if (reason.startsWith("blocked-user:")) {
    highlightCandidates.push(
      deal.querySelector('a[data-t="userLink"]'),
      deal.querySelector(".thread-user")
    );
  } else if (reason === "price-exceeded") {
    highlightCandidates.push(deal.querySelector(".thread-price"));
  }

  highlightCandidates.forEach((element) => {
    if (element) {
      element.classList.add("mdm-temp-override-reason-highlight");
    }
  });

  deal.setAttribute("data-temp-override", "true");
  deal.setAttribute("data-temp-override-reason", reasonLabel);
}

function pruneTimestampMap(mapObj, allowedKeys) {
  let changed = false;
  const allowSet = new Set(allowedKeys);
  Object.keys(mapObj).forEach((key) => {
    if (!allowSet.has(key)) {
      delete mapObj[key];
      changed = true;
    }
  });
  return changed;
}

function ensureWordTimestamps(words, createMissing = false) {
  let changed = false;
  const now = formatTimestamp();
  const legacyTimestamp = GM_getValue("mdm_legacy_timestamp");
  words.forEach((word) => {
    const key = normalizeForSearch(word);
    if (!wordAddedAt[key]) {
      if (createMissing) {
        // Neue Einträge: Exakter aktueller Timestamp
        wordAddedAt[key] = { timestamp: now, isLegacy: false };
        changed = true;
      } else {
        // Alte Einträge: Legacy-Timestamp (ungenau, "vor dem")
        wordAddedAt[key] = { timestamp: legacyTimestamp, isLegacy: true };
        changed = true;
      }
    }
  });
  const removed = pruneTimestampMap(wordAddedAt, words.map(normalizeForSearch));
  if (changed || removed) {
    GM_setValue("wordAddedAt", wordAddedAt);
  }
}

function ensureMerchantTimestamps(merchants, createMissing = false) {
  let changed = false;
  const now = formatTimestamp();
  const legacyTimestamp = GM_getValue("mdm_legacy_timestamp");
  merchants.forEach((merchant) => {
    const key =
      merchant?.id !== undefined && merchant?.id !== null
        ? String(merchant.id)
        : normalizeForSearch(merchant?.name || "");
    if (key && !merchantAddedAt[key]) {
      if (createMissing) {
        // Neue Einträge: Exakter aktueller Timestamp
        merchantAddedAt[key] = { timestamp: now, isLegacy: false };
        changed = true;
      } else {
        // Alte Einträge: Legacy-Timestamp (ungenau, "vor dem")
        merchantAddedAt[key] = { timestamp: legacyTimestamp, isLegacy: true };
        changed = true;
      }
    }
  });
  const allowedKeys = merchants
    .map((m) =>
      m?.id !== undefined && m?.id !== null
        ? String(m.id)
        : normalizeForSearch(m?.name || "")
    )
    .filter(Boolean);
  const removed = pruneTimestampMap(merchantAddedAt, allowedKeys);
  if (changed || removed) {
    GM_setValue("merchantAddedAt", merchantAddedAt);
  }
}

function ensureUserTimestamps(users, createMissing = false) {
  let changed = false;
  const now = formatTimestamp();
  const legacyTimestamp = GM_getValue("mdm_legacy_timestamp");
  users.forEach((user) => {
    const key = (user || "").toLowerCase();
    if (key && !userAddedAt[key]) {
      if (createMissing) {
        // Neue Einträge: Exakter aktueller Timestamp
        userAddedAt[key] = { timestamp: now, isLegacy: false };
        changed = true;
      } else {
        // Alte Einträge: Legacy-Timestamp (ungenau, "vor dem")
        userAddedAt[key] = { timestamp: legacyTimestamp, isLegacy: true };
        changed = true;
      }
    }
  });
  const removed = pruneTimestampMap(
    userAddedAt,
    users.map((u) => (u || "").toLowerCase())
  );
  if (changed || removed) {
    GM_setValue("userAddedAt", userAddedAt);
  }
}

function ensureWhitelistTimestamps(words, createMissing = false) {
  let changed = false;
  const now = formatTimestamp();
  const legacyTimestamp = GM_getValue("mdm_legacy_timestamp");
  words.forEach((word) => {
    const key = normalizeForSearch(word);
    if (!whitelistAddedAt[key]) {
      if (createMissing) {
        whitelistAddedAt[key] = { timestamp: now, isLegacy: false };
      } else {
        whitelistAddedAt[key] = { timestamp: legacyTimestamp, isLegacy: true };
      }
      changed = true;
    } else if (typeof whitelistAddedAt[key] === "string") {
      whitelistAddedAt[key] = {
        timestamp: whitelistAddedAt[key],
        isLegacy: true,
      };
      changed = true;
    }
  });
  const removed = pruneTimestampMap(
    whitelistAddedAt,
    words.map(normalizeForSearch)
  );
  if (changed || removed) {
    GM_setValue("whitelistAddedAt", whitelistAddedAt);
  }
}

function rebuildWhitelistCache(words) {
  const list = Array.isArray(words) ? words : [];
  whitelistCache = list.map((word) => normalizeForSearch(word)).filter(Boolean);
}

function findDealContainer() {
  for (const selector of FEED_CONTAINER_SELECTORS) {
    const element = document.querySelector(selector);
    if (element) {
      if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] 🔍 findDealContainer: Found via selector="${selector}"`);
      return element;
    }
  }

  const firstArticle = document.querySelector(ARTICLE_SELECTOR);
  if (firstArticle?.parentElement) {
    if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] 🔍 findDealContainer: Found via firstArticle.parentElement`);
    return firstArticle.parentElement;
  }

  if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] ⚠️ findDealContainer: NO CONTAINER FOUND! This will break infinite scroll!`);
  return null;
}

function isDealNode(node) {
  if (!node) return false;

  // ELEMENT_NODE
  if (node.nodeType === 1) {
    // Schneller Check: ist der Node selbst ein Deal?
    if (node.matches?.(ARTICLE_SELECTOR)) {
      return true;
    }

    // Langsamer Check: enthält der Node einen Deal?
    // (z.B. Container mit mehreren Deals oder DIV mit 1+ Deals darin)
    try {
      if (node.querySelector?.(ARTICLE_SELECTOR)) {
        return true;
      }
    } catch (e) {
      // Fehler bei querySelector ignorieren (z.B. ungültige Selector)
      if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] isDealNode querySelector error:`, e);
    }

    return false;
  }

  // DOCUMENT_FRAGMENT_NODE - kann mehrere Deals enthalten
  if (node.nodeType === 11) {
    try {
      return !!node.querySelector?.(ARTICLE_SELECTOR);
    } catch (e) {
      return false;
    }
  }

  // Alle anderen nodeTypes (TEXT_NODE=3, COMMENT_NODE=8, etc.) sind keine Deals
  return false;
}

function mutationsAffectDeals(mutations) {
  for (let i = 0; i < mutations.length; i++) {
    const mutation = mutations[i];

    if (mutation.type === "childList") {
      // Schnelle Prüfe auf neue/entfernte Nodes
      if (mutation.addedNodes.length > 0 || mutation.removedNodes.length > 0) {
        // Prüfe jedem einzelnen Node direkt
        if (mutation.addedNodes.length) {
          for (let j = 0; j < mutation.addedNodes.length; j++) {
            if (isDealNode(mutation.addedNodes[j])) {
              if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] ✅ mutationsAffectDeals: isDealNode TRUE in addedNodes[${j}]`);
              return true;
            }
          }
        }

        if (mutation.removedNodes.length) {
          for (let j = 0; j < mutation.removedNodes.length; j++) {
            if (isDealNode(mutation.removedNodes[j])) {
              if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] ✅ mutationsAffectDeals: isDealNode TRUE in removedNodes[${j}]`);
              return true;
            }
          }
        }

        // Fallback: Prüfe auch ob target diese Article-Selector Elemente enthält
        // Das tritt auf beim Infinite Scroll auf Seite 2+, wo der Container-Node Deals hinzufügt
        const target = mutation.target;
        if (target && target.nodeType === 1 && (mutation.addedNodes.length > 0 || mutation.removedNodes.length > 0)) {
          // Prüfe ob target oder addedNodes Deals enthalten
          const hasChildArticles = target.querySelector?.(ARTICLE_SELECTOR);
          if (hasChildArticles) {
            if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] ✅ mutationsAffectDeals: target contains articles`);
            return true;
          }
        }
      }
    }
  }

  if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] ❌ mutationsAffectDeals: No deals detected, returning FALSE`);
  return false;
}

const observerTargets = new WeakMap();

function observeDealMutations(observerInstance) {
  // Suche primär nach dem Deal-Container
  const target = findDealContainer();
  if (!target) {
    if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] 🛑 observeDealMutations: NO TARGET FOUND - Observer cannot be set up!`);
    return;
  }

  const currentTarget = observerTargets.get(observerInstance);
  if (currentTarget === target) {
    if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] ✓ observeDealMutations: Same target, skipping reconnect`);
    return;
  }

  // Beobachter nur neu verbinden wenn nötig
  observerInstance.disconnect();
  if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] 🔄 observeDealMutations: Disconnect + reconnecting observer to new target`);

  observerInstance.observe(target, {
    childList: true, // Neue/entfernte Deals
    attributes: true, // Klassenänderungen, data-Attribute (z.B. mydealz-manager-hidden)
    subtree: true, // Auch in Unter-Elementen
    characterData: false, // Textänderungen ignorieren (Timer-Updates)
  });
  observerTargets.set(observerInstance, target);
  if (DEBUG.infiniteScroll) console.log(`[INFINITE-SCROLL] ✅ observeDealMutations: Observer connected successfully`);
}

