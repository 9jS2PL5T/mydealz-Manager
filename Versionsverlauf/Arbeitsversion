      '<i class="fas fa-shield-alt"></i> Whitelist verwalten';
  }

  if (usersButton) {
    usersButton.innerHTML =
      '<i class="fas fa-user-slash"></i> Benutzerfilter verwalten';
  }

  activeSubUI = null;
}

