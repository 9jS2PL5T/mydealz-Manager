      // PERFORMANCE: Während Scrollen Observer drosseln
      if (isScrolling) {
        const duration = perfTracker.end("observer");
        if (DEBUG.performance.observer) {
          perfTracker.log("observer", "skipped-scrolling", {
            duration: `${duration.toFixed(2)}ms`,
            reason: "User is scrolling - processing deferred"
          });
        }
