// ===== Performance Optimierung =====
// Funktion zur Begrenzung der Ausführungshäufigkeit (Throttling)
function throttle(func, limit, options = { leading: true, trailing: false }) {
  let inThrottle;
  let lastArgs;
  let lastThis;

  return function (...args) {
    lastArgs = args;
    lastThis = this;

    if (!inThrottle) {
      // Führe sofort aus (leading)
      if (options.leading) {
        func.apply(this, args);
      }

      inThrottle = true;

      setTimeout(() => {
        // Wenn trailing aktiviert und es gab weitere Aufrufe
        if (options.trailing && lastArgs) {
          func.apply(lastThis, lastArgs);
        }

        inThrottle = false;
        lastArgs = null;
        lastThis = null;
      }, limit);
    }
  };
}

// === Sortierung ===
// Zentrale Sortierfunktion für Listen
function sortFilterList(list, mode, ascending = true) {
  if (mode === "alphabetical") {
    const sorted = [...list].sort((a, b) => {
      const valA = (a.name || a.word || a.username || a)
        .toString()
        .toLowerCase();
      const valB = (b.name || b.word || b.username || b)
        .toString()
        .toLowerCase();
      return valA.localeCompare(valB, "de", { sensitivity: "base" });
    });
    return ascending ? sorted : sorted.reverse();
  }

  // mode === 'added': Preserve stored order = Neu → Alt; flip only when explicitly requested
  const addedOrder = [...list];
  return ascending ? addedOrder.reverse() : addedOrder;
}

