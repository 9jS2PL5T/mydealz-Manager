// Passt Select-Breite an den aktuell gewählten Option-Text an
function updateSelectWidthToSelectedOption(selectElement) {
  if (!selectElement?.options || !document.body) return;

  const selectedOption = selectElement.options[selectElement.selectedIndex];
  if (!selectedOption) return;

  // Text-Breite messen
  const computed = window.getComputedStyle(selectElement);
  const measure = document.createElement("span");
  measure.style.cssText = `position:absolute;visibility:hidden;white-space:nowrap;font:${computed.font};letter-spacing:${computed.letterSpacing}`;
  measure.textContent = selectedOption.text;
  document.body.appendChild(measure);
  const textWidth = measure.getBoundingClientRect().width;
  document.body.removeChild(measure);

  // Breite berechnen: Text + Padding + Border
  const targetWidth = Math.ceil(
    textWidth +
    (parseFloat(computed.paddingLeft) || 0) +
    (parseFloat(computed.paddingRight) || 0) +
    (parseFloat(computed.borderLeftWidth) || 0) +
    (parseFloat(computed.borderRightWidth) || 0)
  );

  // Breite setzen
  selectElement.style.setProperty("width", `${targetWidth}px`, "important");
  selectElement.style.setProperty("min-width", "0", "important");
  selectElement.style.setProperty("max-width", `${targetWidth}px`, "important");
}

