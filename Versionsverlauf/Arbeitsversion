// Cache für bereits verarbeitete Deals mit maximaler Größe
const MAX_CACHE_SIZE = 500; // Max 500 Deals im Cache
const processedDealsCache = new Map();

// Hash über Filter-Inhalte für Cache-Invalidierung
let excludeWordsHash = 0;
let blockedUsersHash = 0; // Tracking für blockedUsers-Änderungen

function simpleHash(str) {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    const char = str.charCodeAt(i);
    hash = ((hash << 5) - hash) + char;
    hash = hash & hash; // Convert to 32bit integer
  }
  return hash;
}

function extractDealUsername(article, options = {}) {
  const { context = "unknown", debug = false } = options;

  if (!article) {
    if (debug) {
      console.warn("[MDM UserBlock] [extractDealUsername] No article provided", {
        context,
      });
    }
    return { displayName: null, normalizedUsername: null, foundVia: null };
  }

  const attempts = {
    vue3Json: null,
    dataMdAuthor: article.getAttribute("data-md-author") || null,
    userLink: null,
    spanPrimary: null,
    spanAlternate: null,
  };

  let displayName = null;
  let foundVia = null;

  const vueDiv = article.querySelector('.js-vue3[data-vue3]');
  if (vueDiv) {
    try {
      const vueDataAttr = vueDiv.getAttribute("data-vue3");
      if (vueDataAttr) {
        const decodedJson = vueDataAttr
          .replace(/&quot;/g, '"')
          .replace(/&amp;/g, "&")
          .replace(/&lt;/g, "<")
          .replace(/&gt;/g, ">");
        const vueData = JSON.parse(decodedJson);
        attempts.vue3Json = vueData?.props?.thread?.user?.username || null;
      }
    } catch (e) {
      if (debug) {
        console.log("[MDM UserBlock] [extractDealUsername] Vue JSON parse failed", {
          context,
          error: e.message,
        });
      }
    }
  }

  if (attempts.vue3Json) {
    displayName = attempts.vue3Json;
    foundVia = "vue3-json";
  }

  if (!displayName && attempts.dataMdAuthor) {
    displayName = attempts.dataMdAuthor;
    foundVia = "data-md-author";
  }

  if (!displayName) {
    const userLink = article.querySelector('a[data-t="userLink"]');
    attempts.userLink = userLink?.textContent?.trim() || null;
    if (attempts.userLink) {
      displayName = attempts.userLink;
      foundVia = "userLink";
    }
  }

  if (!displayName) {
    const userSpanPrimary = article.querySelector(
      ".overflow--ellipsis.size--all-xs.size--fromW3-s"
    );
    const primaryText = userSpanPrimary?.textContent || "";
    attempts.spanPrimary = primaryText || null;
    const primaryMatch = primaryText.match(/Veröffentlicht von\s+(\S+)/i);
    if (primaryMatch?.[1]) {
      displayName = primaryMatch[1];
      foundVia = "span-text-primary";
    }
  }

  if (!displayName) {
    const userSpanAlternate = article.querySelector(
      ".color--text-TranslucentSecondary.overflow--wrap-off span.overflow--ellipsis"
    );
    const alternateText = userSpanAlternate?.textContent || "";
    attempts.spanAlternate = alternateText || null;
    const alternateMatch = alternateText.match(/Veröffentlicht von\s+(\S+)/i);
    if (alternateMatch?.[1]) {
      displayName = alternateMatch[1];
      foundVia = "span-text-alternate";
    }
  }

  const normalizedUsername = displayName ? displayName.toLowerCase() : null;

  if (debug) {
    console.log("[MDM UserBlock] [extractDealUsername] Result", {
      context,
      dealId: article.getAttribute("id") || null,
      found: !!displayName,
      foundVia,
      displayName,
      normalizedUsername,
      attempts,
    });
  }

  return { displayName, normalizedUsername, foundVia };
}

// Timeout-Tracking für Vue3 Re-Checks (verhindert mehrfache Timeouts pro Deal)
const vue3RecheckScheduled = new Set();
const vue3RecheckTimeouts = new Map(); // Speichert Timeout-IDs zum Abbrechen

// DEBUG: Cache global verfügbar machen (nur für Debugging)
if (typeof unsafeWindow !== "undefined") {
  unsafeWindow.processedDealsCache = processedDealsCache;
} else {
  window.processedDealsCache = processedDealsCache;
}

function addToDealCache(key, value) {
  // Wenn Cache zu groß, ältesten Eintrag entfernen
  if (processedDealsCache.size >= MAX_CACHE_SIZE) {
    const firstKey = processedDealsCache.keys().next().value;
    processedDealsCache.delete(firstKey);

    if (DEBUG.performance.caching) {
      console.log(`[${getDebugTimestamp()}] [MDM Cache] Eviction:`, {
        evictedKey: firstKey,
        reason: "MAX_CACHE_SIZE reached",
        cacheSize: processedDealsCache.size,
      });
      perfTracker.log("caching", "eviction", {
        evictedKey: firstKey,
        reason: "MAX_CACHE_SIZE reached",
        cacheSize: processedDealsCache.size,
      });
    }
  }
  processedDealsCache.set(key, value);
  perfTracker.update("caching.size", processedDealsCache.size);
}

function shouldApplyTemperatureOverride(deal, reason) {
  if (!deal || temperatureOverrideThreshold <= 0) {
    return { shouldOverride: false, temperature: null };
  }

  // Manuell ausgeblendete Deals haben immer Vorrang.
  if (reason === "manually-hidden") {
    return { shouldOverride: false, temperature: null };
  }

  const temperature = getDealTemperature(deal);
  if (temperature === null) {
    return { shouldOverride: false, temperature: null };
  }

  return {
    shouldOverride: temperature >= temperatureOverrideThreshold,
    temperature,
  };
}

// Artikel verarbeiten und filtern
function processArticles(forceRun = false) {
  // Prüfe ob sich Filter geändert haben (wichtig für Early Exit)
  let blockedUsersObj = GM_getValue("blockedUsers", {});
  const currentBlockedUsersHash = simpleHash(Object.keys(blockedUsersObj).sort().join('|'));
  const blockedUsersChanged = currentBlockedUsersHash !== blockedUsersHash;

  // Prüfe ob sich Wortfilter geändert haben
  const currentExcludeWordsHash = simpleHash(excludeWords.join('|'));
  const excludeWordsChanged = currentExcludeWordsHash !== excludeWordsHash;

  // Prüfe ob sich Cold-Deals-Filter geändert hat
  const currentHideColdDeals = GM_getValue("hideColdDeals", false);
  const hideColdDealsChanged = currentHideColdDeals !== hideColdDeals;
  if (hideColdDealsChanged) {
    hideColdDeals = currentHideColdDeals;
  }

  const filtersChanged = blockedUsersChanged || excludeWordsChanged || hideColdDealsChanged;

  if (filtersChanged) {
    // Filter haben sich geändert - Hash aktualisieren
    if (blockedUsersChanged) {
      blockedUsersHash = currentBlockedUsersHash;
    }
    if (excludeWordsChanged) {
      excludeWordsHash = currentExcludeWordsHash;
    }
    // Cache-System wurde entfernt, daher keine Cache-Clear notwendig
    if (DEBUG.wordFilter) {
      console.log('[MDM WordFilter] 🔄 Filter changed:', {
        blockedUsersChanged,
        excludeWordsChanged,
        newBlockedUsersHash: blockedUsersHash,
        newExcludeWordsHash: excludeWordsHash
      });
    }
  }

  // PERFORMANCE OPTIMIZATION REMOVED:
  // Early Exit wurde entfernt, da es Deals überspringen kann die nachträglich laden
  // → Alle Deals werden jetzt bei jedem Durchlauf verarbeitet

  const now = Date.now();
  const currentDealsInDOM = document.querySelectorAll(
    "article.thread--deal, article.thread--voucher"
  ).length;

  if (DEBUG.wordFilter || DEBUG.delayDebug) {
    console.log(
      `[${getDebugTimestamp()}] ✅ [PROCESSING] Batch EXECUTING (no early exit):`,
      {
        forceRun,
        dealCount: currentDealsInDOM,
        merchantLinksChanged: merchantLinksChangedSinceLastBatch,
        filtersChanged,
        dealAttrChanged: dealAttrChangedSinceLastBatch,
        timeSinceLastBatch: `${Math.round((now-lastProcessArticlesTime)/1000)}s`
      }
    );
  }

  // Reset für tracking
  merchantLinksChangedSinceLastBatch = false;
  dealAttrChangedSinceLastBatch = false;
  lastProcessArticlesTime = now;
  lastProcessArticlesDealCount = currentDealsInDOM;

  if (DEBUG.priceFilter) {
    console.log(`[${getDebugTimestamp()}] [MDM PriceFilter] 🔄 processArticles() called, maxPrice=`, maxPrice);
  }

  perfTracker.start("processArticles");
  perfTracker.update("processArticles.calls", 1);
  perfTracker.resetBatch();

  // Batch-Tracking für Vue3-Defers und Performance-Messung
  let vue3DeferredCount = 0;
  const batchStartTime = performance.now();
  let firstTitleUpdateTime = null;

  // Tracking für Delayed Re-Check Optimierung
  let dealsWithoutMerchantId = 0;

  // MerchantFilter Batch-Tracking
  let merchantFilterCheckedCount = 0;
  let merchantFilterHiddenCount = 0;
  const merchantFilterPerDealDebug = false; // Lokale Variable für sehr detaillierte Logs

  // Observer temporär deaktivieren um DOM-Mutations-Loops zu vermeiden
  if (typeof combinedObserver !== 'undefined' && combinedObserver) {
    combinedObserver.disconnect();
  }

  // Log nur beim ersten Aufruf pro Batch (nicht bei jedem Observer-Callback)
  if (DEBUG.hideMatchingMerchantNames && perfTracker.metrics.processArticles.calls === 1) {
    console.log(`[${getDebugTimestamp()}] [MDM MerchantNames] processArticles batch started - Feature state:`, {
      enabled: window.hideMatchingMerchantNames,
      debugEnabled: DEBUG.hideMatchingMerchantNames
    });
  }

  // Lade blockierte Benutzer für die Filterung (Object-Format)
  blockedUsersObj = GM_getValue("blockedUsers", {});
  const blockedUsers = Object.keys(blockedUsersObj); // Nur normalized keys

  if (DEBUG.userBlocking) {
    console.log('[MDM UserBlock] [processArticles] Loaded blocked users:', {
      blockedUsersObj,
      blockedUsers,
      count: blockedUsers.length
    });

    console.log(
      '[MDM UserBlock] Processing articles, blocked users:',
      blockedUsers
    );
  }

  const deals = document.querySelectorAll(
    "article.thread--deal, article.thread--voucher"
  );

  if (DEBUG.performance.processing) {
    perfTracker.log("processing", "start", { dealCount: deals.length });
  }

  perfTracker.update("processArticles.articlesProcessed", deals.length);

  // Cache-System wurde entfernt - keine Cache-Verwaltung mehr nötig

  // Suchseiten-Spezial-Handling: Gefilterte Deals mit Markern anzeigen
  const isSearchPage = window.location.pathname.includes("/search");
  const showFilteredDealsOnSearch = isSearchPage && window.searchFilterMode === "markers";
  const applyFiltersOnSearch = isSearchPage && window.searchFilterMode !== "disabled";
  const filteredDealsOnSearch = []; // { deal, reason, filterDetails }

  // Helper-Funktion: Deal filtern oder auf Suchseite markieren
  const handleFilteredDeal = (deal, reason, filterDetails = null) => {
    const overrideResult = shouldApplyTemperatureOverride(deal, reason);
    if (overrideResult.shouldOverride) {
      applyTemperatureOverrideVisuals(
        deal,
        reason,
        overrideResult.temperature,
        filterDetails || {}
      );
      dealsToShow.push({
        deal,
        reason: `temperature-override:${reason}`,
      });
      return;
    }

    const dealId = deal.getAttribute("id") || "";

    // Prüfe ob Deal manuell vom Nutzer angezeigt wurde - dann nicht wieder verstecken
    if (revealedFilteredDeals.has(dealId)) {
      dealsToShow.push({ deal, reason: "user-revealed" });
      return;
    }

    // Auf Suchseite: Verhalten abhängig vom Filter-Modus
    if (isSearchPage) {
      if (window.searchFilterMode === "disabled") {
        // Modus "Deaktiviert": Deal anzeigen, nicht filtern
        dealsToShow.push({ deal, reason: "search-filters-disabled" });
        return;
      } else if (window.searchFilterMode === "markers" && reason !== "manually-hidden") {
        // Modus "Marker": Deal verstecken UND markieren
        filteredDealsOnSearch.push({ deal, reason, filterDetails });
        dealsToHide.push({ deal, reason });
        return;
      }
      // Modus "full": Fällt durch zu normalem Verstecken
    }

    // Normal: Deal verstecken (auch bei "full" auf Suchseiten)
    dealsToHide.push({ deal, reason });
  };

  // Batch DOM-Updates für bessere Performance
  const dealsToHide = [];
  const dealsToShow = [];

  deals.forEach((deal) => {
    const dealId = deal.getAttribute("id") || "";
    const isCurrentlyHidden = deal.classList.contains("mydealz-manager-hidden");

    if (DEBUG.priceFilter) {
      console.log(`[MDM] 🔍 Processing deal:`, {
        dealId,
        isHidden: isCurrentlyHidden,
        dataHidden: deal.getAttribute("data-hidden-by-mydealz-manager")
      });
    }

    // Prüfe ob Deal manuell versteckt wurde (hat Vorrang)
    if (hiddenDeals.includes(dealId)) {
      if (!isCurrentlyHidden) {
        dealsToHide.push({ deal, reason: "manually-hidden" });
      }
      return;
    }

    // Prüfe ob Deal von blockiertem Benutzer
    if (blockedUsers.length > 0) {
      // blockedUsers enthält bereits normalized keys (lowercase)

      if (DEBUG.userBlocking) {
        console.log("[MDM UserBlock] [processArticles] Checking deal:", {
          dealId,
          blockedUsersCount: blockedUsers.length,
          blockedUsersList: blockedUsers
        });
      }

      const userInfo = extractDealUsername(deal, {
        context: `processArticles:${dealId}`,
        debug: DEBUG.userBlocking,
      });
      const username = userInfo.displayName;

      if (username) {
        const normalizedUsername = username.toLowerCase();
        if (DEBUG.userBlocking) {
          console.log("[MDM UserBlock] [processArticles] Username comparison:", {
            dealId,
            username,
            normalizedUsername,
            blockedUsers,
            isBlocked: blockedUsers.includes(normalizedUsername)
          });
        }

        if (blockedUsers.includes(normalizedUsername)) {
          console.log("[MDM UserBlock] [processArticles] ✅ HIDING deal from blocked user:", {
            dealId,
            username: normalizedUsername,
          });
          handleFilteredDeal(deal, `blocked-user:${normalizedUsername}`, { username });
          return;
        } else {
          if (DEBUG.userBlocking) {
            console.log("[MDM UserBlock] [processArticles] ❌ NOT hiding deal, user not in blocklist:", {
              dealId,
              normalizedUsername,
              blockedUsers
            });
          }
          // User ist NICHT geblockt - wenn Deal wegen THIS USER versteckt wurde, wieder anzeigen
          if (isCurrentlyHidden) {
            const hideReason = deal.getAttribute("data-hide-reason") || "";
            // NUR anzeigen wenn Deal wegen DIESEM User versteckt wurde, NICHT bei anderen Gründen
            if (hideReason === `blocked-user:${normalizedUsername}`) {
              dealsToShow.push({ deal, reason: "user-unblocked" });
              return;
            }
          }
        }
      } else {
        console.log("[MDM UserBlock] [processArticles] ⚠️ NO username found for deal:", dealId);
      }
    } else {
      if (DEBUG.userBlocking) {
        console.log("[MDM UserBlock] [processArticles] ⚠️ blockedUsers list is EMPTY");
      }
      // Keine blockierten User - wenn Deal wegen "blocked-user" versteckt war, wieder anzeigen
      if (isCurrentlyHidden && deal.getAttribute("data-hidden-by-mydealz-manager") === "true") {
        const hideReason = deal.getAttribute("data-hide-reason") || "";
        // NUR anzeigen wenn Deal wegen blockiertem User versteckt wurde, NICHT bei anderen Gründen (word-filter etc.)
        if (hideReason.startsWith("blocked-user:")) {
          dealsToShow.push({ deal, reason: "no-blocked-users" });
          return;
        }
      }
    }

    // Cold Deals Prüfung ZUERST (muss hier sein wegen DOM-Timing)
    if (hideColdDeals) {
      const temperature = getDealTemperature(deal);
      if (temperature !== null && temperature < 0) {
        handleFilteredDeal(deal, `cold-deal:${temperature}°`, { temperature });
        return;
      }
    }

    // Händler-Prüfung ZUERST (muss hier sein wegen DOM-Timing)
    if (
      excludeMerchantsCache.ids.size ||
      excludeMerchantsCache.normalizedNames.size
    ) {
      const merchantInfo = getArticleMerchantInfo(deal);
      const { merchantId, merchantName } = merchantInfo;

      merchantFilterCheckedCount++;

      if (DEBUG.merchantFilter && merchantFilterPerDealDebug) {
        console.log(`[${getDebugTimestamp()}] [MDM MerchantFilter] Checking deal:`, {
          dealId,
          merchantId,
          merchantName,
          normalizedMerchantName: merchantName ? normalizeForSearch(merchantName) : "",
          filteredMerchantIDs: Array.from(excludeMerchantsCache.ids),
          filteredMerchantNames: Array.from(excludeMerchantsCache.normalizedNames)
        });
      }

      if (merchantId && excludeMerchantsCache.ids.has(String(merchantId))) {
        merchantFilterHiddenCount++;
        if (DEBUG.merchantFilter) {
          console.log(`[${getDebugTimestamp()}] [MDM MerchantFilter] ⛔ Hiding deal due to merchant match:`, {
            dealId,
            merchantId,
            merchantName,
            matchType: "id",
            matchValue: merchantId
          });
        }
        handleFilteredDeal(deal, `merchant-id:${merchantId}`, { merchantId, merchantName });
        return;
      }

      const normalizedMerchantName = merchantName
        ? normalizeForSearch(merchantName)
        : "";
      if (
        normalizedMerchantName &&
        excludeMerchantsCache.normalizedNames.has(normalizedMerchantName)
      ) {
        merchantFilterHiddenCount++;
        if (DEBUG.merchantFilter) {
          console.log(`[${getDebugTimestamp()}] [MDM MerchantFilter] ⛔ Hiding deal due to merchant match:`, {
            dealId,
            merchantId,
            merchantName,
            matchType: "name",
            matchValue: normalizedMerchantName
          });
        }
        handleFilteredDeal(deal, `merchant-name:${merchantName}`, { merchantId, merchantName });
        return;
      }

      // Tracking: Deal ohne merchantId zählen (für Delayed Re-Check Optimierung)
      if (!merchantId) {
        dealsWithoutMerchantId++;
      }
    }

    // WICHTIG: Vue3-Check ZUERST! Verhindert, dass Titel-Änderungen von Vue überschrieben werden
    // Vue rendert Deals asynchron - wir müssen warten, bis der Render-Prozess abgeschlossen ist
    const vue3Container = deal.querySelector('.js-vue3[data-handler="vue3"]');
    if (vue3Container && vue3Container.children.length === 0) {
      // Vue3 hat noch nicht gerendert - wir müssen warten!
      vue3DeferredCount++; // Batch-Counter erhöhen statt einzeln zu loggen

      // Detailliertes per-Deal-Log nur unter DEBUG.performance.observer
      if (DEBUG.performance.observer) {
        console.log(`[${getDebugTimestamp()}] [MDM] ⏳ Vue3 container empty (deal ${vue3DeferredCount}):`, dealId);
      }

      // Timeout setzen für Re-Check nach 500ms
      if (!vue3RecheckScheduled.has(dealId)) {
        vue3RecheckScheduled.add(dealId);
        const timeoutId = setTimeout(() => {
          vue3RecheckScheduled.delete(dealId);
          vue3RecheckTimeouts.delete(dealId);
          // Re-processing-Log nur unter DEBUG.performance.observer
          if (DEBUG.performance.observer) {
            console.log(`[${getDebugTimestamp()}] [MDM] 🔄 Re-processing after Vue3 render:`, dealId);
          }
          processArticles();
        }, 500);
        vue3RecheckTimeouts.set(dealId, timeoutId);
      }

      // Deal NICHT verarbeiten - beim nächsten Durchlauf (wenn Vue fertig) neu prüfen
      dealsToShow.push({ deal, reason: "vue3-not-rendered-yet" });
      return;
    }

    // Vue3 ist fertig - Timeout abbrechen falls vorhanden
    if (vue3RecheckScheduled.has(dealId)) {
      const timeoutId = vue3RecheckTimeouts.get(dealId);
      if (timeoutId) {
        clearTimeout(timeoutId);
        // Timeout-Cancel-Log nur unter DEBUG.performance.observer
        if (DEBUG.performance.observer) {
          console.log(`[${getDebugTimestamp()}] [MDM] ⏹️ Vue3 ready, cancelled timeout:`, dealId);
        }
      }
      vue3RecheckScheduled.delete(dealId);
      vue3RecheckTimeouts.delete(dealId);
    }

    // WICHTIG: Händlernamen-Feature MUSS VOR Wortfilter laufen!
    // Grund: Der Wortfilter soll die GEÄNDERTEN Titel sehen, nicht die Originale
    let titleWasChanged = false;

    if (window.hideMatchingMerchantNames && !ORIGINAL_TITLES.has(dealId)) {
      // WICHTIG: Speichere Originaltitel auch für Deals OHNE Merchant-Info
      // Dies ist essentiell, damit der Wortfilter konsistent auf Originaltitel arbeiten kann
      const titleLink = deal.querySelector(".thread-title a");
      if (titleLink && !ORIGINAL_TITLES.has(dealId)) {
        ORIGINAL_TITLES.set(dealId, titleLink.textContent);
      }

      // Priorität 1: Suche merchantLink mit ID im GESAMTEN Deal
      const merchantLink = deal.querySelector('a[data-t="merchantLink"]');

      // Priorität 2: Fallback für Händler ohne ID - Suche im "Verfügbar bei" Span
      let fallbackMerchantSpan = null;
      if (!merchantLink) {
        // Suche nach "Verfügbar bei <span>händlername</span>" Struktur
        const merchantInfoSpans = deal.querySelectorAll('.color--text-TranslucentSecondary.size--all-xs span');
        for (const span of merchantInfoSpans) {
          const text = span.textContent?.trim();
          // Prüfe ob es ein Händlername sein könnte (z.B. "deblock.com")
          if (text && (text.includes('.') || text.length > 3)) {
            fallbackMerchantSpan = span;
            break;
          }
        }
      }

      // Debug: Alle Links und Merchant-Infos analysieren
      if (DEBUG.hideMatchingMerchantNames && (merchantLink || fallbackMerchantSpan)) {
        const titleLink = deal.querySelector(".thread-title a");
        const allLinksInDeal = deal.querySelectorAll('a');
        const allDataTLinks = deal.querySelectorAll('a[data-t]');
        const merchantLinks = deal.querySelectorAll('a[data-t="merchantLink"]');

        console.log(`[${getDebugTimestamp()}] [MDM MerchantNames] Deal analysis:`, {
          dealId,
          hasLink: !!merchantLink,
          merchantName: merchantLink?.textContent?.trim() || "none",
          hasFallbackSpan: !!fallbackMerchantSpan,
          fallbackMerchantName: fallbackMerchantSpan?.textContent?.trim() || "none",
          title: titleLink?.textContent,
          allLinksInDeal: allLinksInDeal.length,
          allDataTLinks: allDataTLinks.length,
          merchantLinksCount: merchantLinks.length,
          dataTAttributes: Array.from(allDataTLinks).map(l => l.getAttribute('data-t'))
        });
      }

      // Verarbeite Titel wenn Händlerinfo verfügbar ist
      if (merchantLink || fallbackMerchantSpan) {
        const titleElement = deal.querySelector(".thread-title");
        if (titleElement) {
          const merchantName = merchantLink
            ? merchantLink.textContent.trim()
            : fallbackMerchantSpan.textContent.trim();

          const titleLink = titleElement.querySelector("a");
          if (titleLink) {
            // Originaltitel wurde bereits oben gespeichert, hole ihn von dort
            const originalTitle = ORIGINAL_TITLES.get(dealId) || titleLink.textContent;
            const newTitle = removeMerchantNameFromTitle(originalTitle, merchantName);

            if (originalTitle !== newTitle) {
              titleLink.textContent = newTitle;
              titleLink.setAttribute("title", newTitle);
              titleWasChanged = true; // Flag setzen: Titel wurde geändert!

              // Timing: Erster Title-Update in diesem Batch
              if (firstTitleUpdateTime === null) {
                firstTitleUpdateTime = performance.now();
              }

              if (DEBUG.hideMatchingMerchantNames) {
                console.log(`[${getDebugTimestamp()}] [MDM MerchantNames] Title updated:`, {
                  dealId,
                  before: originalTitle,
                  after: newTitle,
                  titleWasChanged: true
                });
              }

              perfTracker.update("domUpdates.titleChanges", 1);
              perfTracker.currentBatch.domUpdates.titleChanges++;

              // Cache-System wurde entfernt - keine Cache-Invalidierung nötig
            } else if (DEBUG.hideMatchingMerchantNames) {
              console.log(`[${getDebugTimestamp()}] [MDM MerchantNames] No title change needed:`, {
                dealId,
                title: originalTitle
              });
            }
          }
        } else if (DEBUG.criticalErrors) {
          console.warn('[MDM Critical] ⚠ hideMatchingMerchantNames: Selector ".thread-title" returned no element for deal:', dealId);
        }
      }
    } else if (window.hideMatchingMerchantNames && ORIGINAL_TITLES.has(dealId)) {
      // Feature ist AN, aber Deal wurde bereits verarbeitet - SKIP (kein Log nötig)
      // Der Titel wurde bereits beim ersten Durchlauf geändert
    } else if (!window.hideMatchingMerchantNames && ORIGINAL_TITLES.has(dealId)) {
      // Feature deaktiviert: Originaltitel wiederherstellen
      if (DEBUG.hideMatchingMerchantNames) {
        console.log(`[${getDebugTimestamp()}] [MDM MerchantNames] Feature is DISABLED, restoring original title for:`, dealId);
      }
      const titleLink = deal.querySelector(".thread-title a");
      if (titleLink) {
        const originalTitle = ORIGINAL_TITLES.get(dealId);
        titleLink.textContent = originalTitle;
        titleLink.setAttribute("title", originalTitle);
        if (DEBUG.hideMatchingMerchantNames) {
          console.log(`[${getDebugTimestamp()}] [MDM MerchantNames] Restored original title:`, originalTitle);
        }
      }
    }

    // PREIS-FILTER: Immer ZUERST prüfen, unabhängig vom Cache!
    // Preise ändern sich nicht und sollten immer sofort gefiltert werden
    let priceCheckPassed = false; // Flag: Wurde Preis-Check durchgeführt?

    if (maxPrice > 0) {
      // Vue3 ist an dieser Stelle bereits fertig gerendert (Check wurde oben durchgeführt)
      const priceElement = deal.querySelector(".thread-price");

      if (!priceElement) {
        if (DEBUG.priceFilter) {
          console.warn(`[${getDebugTimestamp()}] [MDM PriceFilter] ⚠️ .thread-price missing:`, {
            dealId
          });
        }
        // Kein Preis gefunden - aber TROTZDEM Wortfilter anwenden!
        // NICHT sofort anzeigen - weitermachen mit Cache/shouldExcludeArticle
        priceCheckPassed = true; // Preis-Check überspringen, aber Wortfilter anwenden
      } else {
        // Preis-Element gefunden - jetzt auswerten
        priceCheckPassed = true;
        const priceText = priceElement.textContent.trim();

        if (DEBUG.priceFilter) {
          console.log(`[${getDebugTimestamp()}] [MDM PriceFilter] 💰 Checking price:`, {
            dealId,
            priceText,
            maxPrice
          });
        }

        // Preis extrahieren
        if (!priceText.includes("%") && !priceText.startsWith("-") && priceText.includes("€")) {
          const euroFormatMatch = priceText.match(/([\d.,]+)\s*€/);
          if (euroFormatMatch) {
            let extractedPrice = euroFormatMatch[1];
            extractedPrice = extractedPrice.replace(/\./g, "");
            extractedPrice = extractedPrice.replace(",", ".");
            const priceValue = parseFloat(extractedPrice);

            if (!isNaN(priceValue) && priceValue > maxPrice) {
              if (DEBUG.priceFilter) {
                console.log(`[${getDebugTimestamp()}] [MDM PriceFilter] 🚫 HIDING - price exceeds:`, {
                  dealId,
                  price: priceValue,
                  maxPrice,
                  diff: priceValue - maxPrice
                });
              }
              handleFilteredDeal(deal, "price-exceeded", { price: priceValue, maxPrice });
              return;
            }
          }
        }
      }
    }

    // PERFORMANCE OPTIMIZATION REMOVED:
    // Cache wurde entfernt, da er unvollständig geladene Deals als "ok" markiert
    // → Alle Deals werden jetzt immer frisch evaluiert

    // WICHTIG: Erstelle normalisierten Titel für konsistente Filter-Anwendung
    // KRITISCH: Wenn hideMatchingMerchantNames aktiv ist, nutze ORIGINAL_TITLES!
    const titleLink = deal.querySelector(".thread-title a");
    let titleForFilter;

    if (window.hideMatchingMerchantNames && ORIGINAL_TITLES.has(dealId)) {
      // Nutze Originaltitel, damit Händlernamen im Wortfilter erkannt werden
      titleForFilter = ORIGINAL_TITLES.get(dealId);
    } else {
      // Nutze sichtbaren Titel
      titleForFilter = titleLink?.textContent || "";
    }

    const normalizedTitleForFilter = normalizeForSearch(titleForFilter);

    const filterResult = shouldExcludeArticle(deal, normalizedTitleForFilter);

    if (DEBUG.wordFilter && filterResult.shouldExclude) {
      console.log(`[${getDebugTimestamp()}] [MDM Filter] Deal EXCLUDED:`, {
        dealId,
        titleForFilter,
        usedOriginalTitle: window.hideMatchingMerchantNames && ORIGINAL_TITLES.has(dealId),
        normalizedTitle: normalizedTitleForFilter,
        matchedWord: filterResult.matchedWord
      });
    }

    if (filterResult.shouldExclude) {
      handleFilteredDeal(deal, "word-filter", { matchedWord: filterResult.matchedWord });
      return;
    }

    dealsToShow.push({ deal, reason: "no-filter-match" });
  });

  // Batch DOM-Updates: Alle auf einmal anwenden für bessere Performance
  dealsToHide.forEach((item) => {
    if (item.deal) {
      hideDeal(item.deal, item.reason);
    } else {
      hideDeal(item, "legacy");
    }
  });
  dealsToShow.forEach((item) => {
    if (item.deal) {
      showDeal(item.deal, item.reason);
    } else {
      showDeal(item, "legacy");
    }
  });

  // Suchseiten-Spezial-Handling: Marker und Zusammenfassungs-Box einfügen
  if (showFilteredDealsOnSearch && filteredDealsOnSearch.length > 0) {
    createFilteredDealsUI(filteredDealsOnSearch);
  } else {
    // Entferne alte Marker/Boxen wenn Feature deaktiviert wurde
    removeFilteredDealsUI();
  }

  // processSucheinstellungen() wird nur EINMAL in init() aufgerufen,
  // NICHT in jedem processArticles()-Durchlauf (verhindert Endlosschleife/Reloads)

  const duration = perfTracker.end("processArticles");
  perfTracker.update("processArticles.totalTime", duration);

  // Log aggregierte Batch-Daten
  perfTracker.logBatch();

  if (DEBUG.performance.processing) {
    perfTracker.log("processing", "completed", {
      duration: `${duration.toFixed(2)}ms`,
      articlesProcessed: deals.length,
      avgTimePerArticle:
        deals.length > 0 ? `${(duration / deals.length).toFixed(3)}ms` : "0ms",
      batchSize: { hidden: dealsToHide.length, shown: dealsToShow.length },
    });
  }

  // UI-Updates NACH DOM-Änderungen
  addSettingsButton();
  addHideButtons();

  // ENTFERNT: observeDealMutations(combinedObserver) - War tödlich für Infinite Scroll!
  // Jedes Mal disconnect+reconnect stoppte neue Deals vom Laden

  // MerchantFilter Batch-Zusammenfassung
  if (DEBUG.merchantFilter && merchantFilterCheckedCount > 0) {
    console.log(`[${getDebugTimestamp()}] [MDM MerchantFilter] ✅ Batch done – checked ${merchantFilterCheckedCount} deals, hidden ${merchantFilterHiddenCount}`);
  }

  // DELAYED RE-CHECK für Merchant-Filter
  // Problem: Bei Tab-Wechsel/Reload laden merchantIds asynchron NACH processArticles
  // Lösung: Nach 2 Sekunden erneut prüfen ob Deals mit merchantId jetzt versteckt werden müssen
  // Optimierung: Nur planen wenn tatsächlich Deals ohne merchantId existieren
  const currentDealCount = deals.length;
  const timeSinceLastRecheck = Date.now() - lastSuccessfulMerchantRecheck;

  if (
    dealsWithoutMerchantId > 0 &&
    (excludeMerchantsCache.ids.size > 0 || excludeMerchantsCache.normalizedNames.size > 0) &&
    !delayedMerchantRecheckScheduled &&
    // Intelligente Guards: Nur bei neuen Deals ODER nach Cooldown
    (
      currentDealCount > lastKnownDealCount || // Neue Deals im DOM
      timeSinceLastRecheck > 10000 // 10s Cooldown
    )
  ) {
    lastKnownDealCount = currentDealCount;
    delayedMerchantRecheckScheduled = true;

    setTimeout(() => {
      // Prüfe alle sichtbaren Deals nochmal
      const visibleDeals = document.querySelectorAll(
        'article.thread--deal:not(.mydealz-manager-hidden), article.thread--voucher:not(.mydealz-manager-hidden)'
      );

      if (DEBUG.merchantFilter) {
        console.log(`[${getDebugTimestamp()}] [MDM MerchantFilter] 🔎 Delayed Re-Check start – checking ${visibleDeals.length} deals`);
      }

      let recheckHiddenCount = 0;
      visibleDeals.forEach((deal) => {
        const dealId = deal.getAttribute("id") || "";
        const merchantInfo = getArticleMerchantInfo(deal);
        const { merchantId, merchantName } = merchantInfo;

        // Prüfe ob dieser Deal jetzt eine merchantId hat und gefiltert werden soll
        if (merchantId && excludeMerchantsCache.ids.has(String(merchantId))) {
          if (DEBUG.merchantFilter) {
            console.log(`[${getDebugTimestamp()}] [MDM MerchantFilter] ⛔ Hiding deal due to merchant match (delayed):`, {
              dealId,
              merchantId,
              merchantName,
              matchType: "id",
              matchValue: merchantId
            });
          }
          hideDeal(deal, `delayed-merchant-id:${merchantId}`);
          recheckHiddenCount++;
        } else if (merchantName) {
          const normalizedMerchantName = normalizeForSearch(merchantName);
          if (excludeMerchantsCache.normalizedNames.has(normalizedMerchantName)) {
            if (DEBUG.merchantFilter) {
              console.log(`[${getDebugTimestamp()}] [MDM MerchantFilter] ⛔ Hiding deal due to merchant match (delayed):`, {
                dealId,
                merchantId,
                merchantName,
                matchType: "name",
                matchValue: normalizedMerchantName
              });
            }
            hideDeal(deal, `delayed-merchant-name:${merchantName}`);
            recheckHiddenCount++;
          }
        }
      });

      // Logging: Nur bei tatsächlichem Erfolg (additionallyHidden > 0)
      if (DEBUG.merchantFilter && recheckHiddenCount > 0) {
        console.log(`[${getDebugTimestamp()}] [MDM MerchantFilter] ✅ Delayed Re-Check done – checked ${visibleDeals.length} deals, hidden ${recheckHiddenCount}`);
      }

      // Flag zurücksetzen - ermöglicht neue Re-Checks für zukünftige Batches
      lastSuccessfulMerchantRecheck = Date.now();
      delayedMerchantRecheckScheduled = false;
    }, 2000); // 2 Sekunden Delay
  }

  // === Batch-Ende Logging ===

  // Aggregiertes Vue3-Defer-Logging (ersetzt viele Einzel-Logs)
  if (DEBUG.performance.lazyRenderSummary && vue3DeferredCount > 0) {
    console.log(
      `[${getDebugTimestamp()}] [MDM] Deals mit verzögerter Anzeige: ${vue3DeferredCount} Deal(s) werden später erneut geprüft.`
    );
  }

  // Performance-Messung: Zeit bis zum ersten Title-Update
  if (DEBUG.performance.processing && deals.length > 0) {
    const timeToFirstUpdate = firstTitleUpdateTime !== null
      ? (firstTitleUpdateTime - batchStartTime).toFixed(2)
      : 'N/A';

    console.log(`[${getDebugTimestamp()}] [MDM Performance] Batch completed:`, {
      totalDeals: deals.length,
      vue3Deferred: vue3DeferredCount,
      timeToFirstTitleUpdate_ms: timeToFirstUpdate
    });
  }
}

// ===== Suchseiten-Spezial-Handling =====
// Marker und Zusammenfassungs-Box für gefilterte Deals auf Suchseiten
let lastFilteredDealsCount = 0; // Tracking um unnötige Re-Renders zu vermeiden

function createFilteredDealsUI(filteredDeals) {
  const colors = getThemeColors();

  // Early Return: Wenn keine Änderung bei Anzahl der gefilterten Deals, abbrechen
  if (filteredDeals.length === lastFilteredDealsCount && filteredDeals.length > 0) {
    return;
  }
  lastFilteredDealsCount = filteredDeals.length;

  // 1. Zusammenfassungs-Box oben erstellen/aktualisieren
  const dealContainer = findDealContainer();
  if (!dealContainer) return;

  // Entferne alte Box falls vorhanden
  const oldSummary = document.getElementById("mdm-filtered-deals-summary");
  if (oldSummary) oldSummary.remove();

  // Zähle Filter-Typen
  const filterCounts = {};
  filteredDeals.forEach(({ reason }) => {
    const filterType = reason.split(':')[0];
    filterCounts[filterType] = (filterCounts[filterType] || 0) + 1;
  });

  // Erstelle Zusammenfassungs-Box
  const summaryBox = document.createElement("div");
  summaryBox.id = "mdm-filtered-deals-summary";
  summaryBox.style.cssText = `
    background: ${colors.background};
    border: 2px solid #ff9800;
    border-radius: 8px;
    padding: 12px 16px;
    margin: 16px 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  `;

  const filterTypesHTML = Object.entries(filterCounts).map(([type, count]) => {
    const labels = {
      'blocked-user': 'Blockierte Benutzer',
      'cold-deal': 'Kalte Deals',
      'merchant-id': 'Händlerfilter',
      'merchant-name': 'Händlerfilter',
      'price-exceeded': 'Preisfilter',
      'word-filter': 'Wortfilter'
    };
    return `<span style="display: inline-block; margin-right: 12px;">• ${count}× ${labels[type] || type}</span>`;
  }).join('');

  summaryBox.innerHTML = `
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px;">
      <div style="flex: 1;">
        <div style="font-weight: bold; font-size: 16px; margin-bottom: 6px; color: ${colors.text};">
          ⚠️ ${filteredDeals.length} Deal${filteredDeals.length !== 1 ? 's' : ''} durch Filter ausgeblendet
        </div>
        <div style="font-size: 13px; color: ${colors.text}; opacity: 0.8;">
          ${filterTypesHTML}
        </div>
      </div>
      <div style="display: flex; gap: 8px;">
        <button class="mdm-show-all-filtered-btn" style="
          padding: 8px 16px;
          background: #ff9800;
          color: white;
          border: none;
          border-radius: 4px;
          cursor: pointer;
          font-weight: bold;
          white-space: nowrap;
        ">Alle anzeigen</button>
      </div>
    </div>
  `;

  // Füge Box am Anfang der Deal-Liste ein
  dealContainer.insertBefore(summaryBox, dealContainer.firstChild);

  // Event-Handler für "Alle anzeigen" - mit Delegation
  summaryBox.querySelector(".mdm-show-all-filtered-btn")?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();

    filteredDeals.forEach(({ deal }) => {
      const dealId = deal.getAttribute("id") || "";
      if (dealId) { // Nur wenn Deal-ID vorhanden
        revealedFilteredDeals.add(dealId);
      }

      const marker = deal.previousElementSibling;
      if (marker?.classList.contains("mdm-filter-marker")) {
        marker.remove();
      }
      showDeal(deal, "search-revealed");
    });
    summaryBox.remove();
  });

  // 2. Inline-Marker für jeden gefilterten Deal erstellen
  filteredDeals.forEach(({ deal, reason, filterDetails }) => {
    const dealId = deal.getAttribute("id") || "";

    // Prüfe ob Marker bereits existiert - WICHTIG
    const existingMarker = deal.previousElementSibling;
    if (existingMarker?.classList.contains("mdm-filter-marker")) {
      // Marker existiert bereits, überspringen
      return;
    }

    // Erstelle Marker
    const marker = document.createElement("div");
    marker.classList.add("mdm-filter-marker");
    marker.setAttribute("data-deal-id", dealId);
    marker.style.cssText = `
      background: ${colors.background};
      border: 1px solid #ff9800;
      border-radius: 4px;
      padding: 8px 12px;
      margin: 8px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 13px;
      color: ${colors.text};
    `;

    // Filter-Beschreibung erstellen
    const getFilterDescription = (reason, details) => {
      const type = reason.split(':')[0];

      // Hilfsfunktion: Text auf Max-Länge kürzen
      const truncate = (text, maxLen = 40) => {
        if (!text) return '';
        return text.length > maxLen ? text.substring(0, maxLen).trim() + '...' : text;
      };

      switch (type) {
        case 'blocked-user':
          return `👤 ${details?.username || 'Blockierter Benutzer'}`;
        case 'cold-deal':
          return `❄️ Kalter Deal (${details?.temperature || '?'}°)`;
        case 'merchant-id':
        case 'merchant-name':
          return `🏪 ${details?.merchantName || 'Händler'}`;
        case 'price-exceeded':
          return `💰 ${details?.price?.toFixed(2) || '?'}€ > ${details?.maxPrice || '?'}€`;
        case 'word-filter': {
          const word = details?.matchedWord || '';
          return `🔤 ${truncate(word)}`;
        }
        default:
          return `⚙️ ${type}`;
      }
    };

    marker.innerHTML = `
      <div style="flex: 1; display: flex; align-items: center; gap: 8px;">
        <span style="opacity: 0.6;">━━━</span>
        <span>${getFilterDescription(reason, filterDetails)}</span>
      </div>
      <button class="mdm-show-filtered-deal-btn" data-deal-id="${dealId}" style="
        padding: 4px 12px;
        background: transparent;
        border: 1px solid ${colors.border};
        border-radius: 4px;
        cursor: pointer;
        color: ${colors.text};
        white-space: nowrap;
        font-size: 12px;
      ">▼ Anzeigen</button>
    `;

    // Füge Marker vor dem Deal ein
    deal.parentElement.insertBefore(marker, deal);

    // Event-Handler für "Anzeigen" Button mit eingebauter Deal-ID
    marker.querySelector(".mdm-show-filtered-deal-btn")?.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();

      const buttonDealId = e.target.getAttribute("data-deal-id");
      if (buttonDealId) {
        revealedFilteredDeals.add(buttonDealId);
      }

      marker.remove();
      showDeal(deal, "search-revealed");

      // Aktualisiere Zusammenfassungs-Box
      const remainingMarkers = document.querySelectorAll(".mdm-filter-marker");
      if (remainingMarkers.length === 0) {
        summaryBox.remove();
      } else {
        const countText = summaryBox.querySelector("div[style*='font-weight: bold']");
        if (countText) {
          countText.textContent = `⚠️ ${remainingMarkers.length} Deal${remainingMarkers.length !== 1 ? 's' : ''} durch Filter ausgeblendet`;
        }
      }
    });
  });
}

function removeFilteredDealsUI() {
  // Entferne Zusammenfassungs-Box
  document.getElementById("mdm-filtered-deals-summary")?.remove();

  // Entferne alle Marker
  document.querySelectorAll(".mdm-filter-marker").forEach(marker => marker.remove());
}

// ===== Filterlogik =====
// Ausschlussprüfung für Artikel
function shouldExcludeArticle(article, normalizedTitleForFilter = null) {
  const titleElement = article.querySelector(".thread-title");
  if (!titleElement) {
    return { shouldExclude: false, reason: "no-title-element" };
  }

  if (DEBUG.priceFilter) {
    console.log("[MDM PriceFilter] 🔍 Checking article:", {
      articleId: article.id,
      maxPrice: maxPrice,
      maxPriceType: typeof maxPrice,
      willCheckPrice: maxPrice > 0,
      reason: maxPrice > 0 ? "Preis-Check wird durchgeführt" : "⚠️ maxPrice ist 0 - KEIN Preis-Check!"
    });
  }

  if (maxPrice > 0) {
    perfTracker.start("priceFilter");
    perfTracker.update("filtering.priceFilter.calls", 1);

    const priceSelectors = [".thread-price", ".text--color-greyShade", ".color--text-NeutralSecondary"];
    let foundPrice = false;
    let checkedSelectors = [];

    for (const selector of priceSelectors) {
      const priceElement = article.querySelector(selector);
      if (!priceElement) {
        checkedSelectors.push({ selector, found: false });
        if (DEBUG.priceFilterVerbose) {
          console.log(`[MDM PriceFilter] ❌ Selector '${selector}' not found in article ${article.id}`);
        }
        continue;
      }

      checkedSelectors.push({ selector, found: true });
      foundPrice = true;

      const priceText = priceElement.textContent.trim();

      if (DEBUG.priceFilterVerbose) {
        console.log("[MDM PriceFilter] ✅ Found price element:", {
          articleId: article.id,
          selector,
          text: priceText,
        });
      }

      if (priceText.includes("%")) {
        if (DEBUG.priceFilterVerbose) console.log("[MDM PriceFilter] ⏭️ Skipped: contains %");
        continue;
      }
      if (priceText.startsWith("-")) {
        if (DEBUG.priceFilterVerbose) console.log("[MDM PriceFilter] ⏭️ Skipped: starts with -");
        continue;
      }
      if (!priceText.includes("€")) {
        if (DEBUG.priceFilterVerbose) console.log("[MDM PriceFilter] ⏭️ Skipped: no € symbol");
        continue;
      }

      const euroFormatMatch = priceText.match(/([\d.,]+)\s*€/);
      if (euroFormatMatch) {
        let extractedPrice = euroFormatMatch[1];

        if (DEBUG.priceFilterVerbose) {
          console.log("[MDM PriceFilter] 📊 Extracting price:", {
            articleId: article.id,
            rawMatch: euroFormatMatch[1],
            step1_removeDots: extractedPrice.replace(/\./g, ""),
            step2_replaceComma: extractedPrice.replace(/\./g, "").replace(",", ".")
          });
        }

        extractedPrice = extractedPrice.replace(/\./g, "");
        extractedPrice = extractedPrice.replace(",", ".");

        const priceValue = parseFloat(extractedPrice);

        if (DEBUG.priceFilterVerbose) {
          console.log("[MDM PriceFilter] 💰 Price comparison:", {
            articleId: article.id,
            extractedString: extractedPrice,
            parsedValue: priceValue,
            maxPrice: maxPrice,
            exceeds: priceValue > maxPrice,
            isValid: !isNaN(priceValue)
          });
        }

        if (!isNaN(priceValue) && priceValue > maxPrice) {
          perfTracker.update("filtering.priceFilter.hits", 1);
          perfTracker.currentBatch.filtering.priceExceeded++;

          if (DEBUG.priceFilter) {
            console.log("[MDM PriceFilter] 🚫 HIDING: Price exceeds max:", {
              articleId: article.id,
              price: priceValue,
              maxPrice: maxPrice,
              difference: priceValue - maxPrice
            });
          }

          const duration = perfTracker.end("priceFilter");
          perfTracker.update("filtering.priceFilter.totalTime", duration);

          return true;
        } else if (DEBUG.priceFilterVerbose) {
          console.log("[MDM PriceFilter] ✅ KEEPING: Price is OK:", {
            articleId: article.id,
            price: priceValue,
            maxPrice: maxPrice
          });
        }
      } else if (DEBUG.priceFilterVerbose) {
        console.log("[MDM PriceFilter] ⚠️ No price match in text:", priceText);
      }
    }

    if (!foundPrice) {
      if (DEBUG.priceFilter) {
        console.warn(
          "[MDM PriceFilter] ⚠️ NO PRICE FOUND for article:", article.id
        );
        console.warn("[MDM PriceFilter] Checked selectors:", checkedSelectors);
      }
      if (DEBUG.criticalErrors) {
        console.warn(
          "[MDM Critical] ⚠ priceFilter: ALLE Preis-Selektoren fehlgeschlagen!"
        );
        console.warn("[MDM Critical] Checked selectors:", checkedSelectors);
        console.warn("[MDM Critical] Article ID:", article.id);
      }
    }

    const duration = perfTracker.end("priceFilter");
    perfTracker.update("filtering.priceFilter.totalTime", duration);
  }

  const titleLink = titleElement.querySelector("a");

  // KRITISCH: Wenn hideMatchingMerchantNames aktiv ist, muss der Wortfilter auf den ORIGINALTITEL
  // angewendet werden, nicht auf den bereits bereinigten Titel!
  // Ansonsten werden Deals mit bereits entferntem Händlernamen nicht gefiltert.
  const dealId = article.id || article.getAttribute("data-thread-id");
  let rawTitle;

  if (window.hideMatchingMerchantNames && dealId && ORIGINAL_TITLES.has(dealId)) {
    // Nutze Originaltitel für Wortfilter, damit Händlernamen erkannt werden
    rawTitle = ORIGINAL_TITLES.get(dealId);
  } else {
    // Nutze sichtbaren Titel
    rawTitle = titleLink?.getAttribute("title") || titleElement.innerText;
  }

  // WICHTIG: Nutze übergebenen normalizedTitleForFilter wenn vorhanden, sonst neu erstellen
  // Dies stellt sicher, dass der Wortfilter den GLEICHEN Titel sieht wie die Cache-Logik
  const normalizedTitle = normalizedTitleForFilter || normalizeForSearch(rawTitle);

  if (DEBUG.wordFilter) {
    console.log("[MDM WordFilter] shouldExcludeArticle START:", {
      articleId: article.id,
      dealId,
      rawTitle,
      normalizedTitle,
      usedOriginalTitle: window.hideMatchingMerchantNames && dealId && ORIGINAL_TITLES.has(dealId),
      normalizedTitleForFilterProvided: !!normalizedTitleForFilter,
      titleAttribute: titleLink?.getAttribute("title"),
      textContent: titleLink?.textContent,
      innerText: titleElement.innerText,
      totalFilters: excludeWordCache.length,
      hideMatchingMerchantNamesActive: window.hideMatchingMerchantNames
    });
  }

  if (!normalizedTitle) {
    return false;
  }

  // WHITELIST-PRÜFUNG: Wenn Titel Whitelist-Wort enthält, NICHT ausblenden
  if (whitelistCache.length > 0) {
    if (DEBUG.wordFilter) {
      console.log("[MDM Whitelist] Checking whitelist:", {
        whitelistWords: whitelistCache.join(", ")
      });
    }
    for (const whitelistWord of whitelistCache) {
      if (normalizedTitle.includes(whitelistWord)) {
        if (DEBUG.wordFilter) {
          console.log("[MDM Whitelist] ✓ Deal PROTECTED:", {
            title: normalizedTitle,
            matchedWord: whitelistWord,
          });
        }
        return false; // Deal NICHT ausblenden
      }
    }
    if (DEBUG.wordFilter) {
      console.log("[MDM Whitelist] No whitelist match");
    }
  }

  if (excludeWordCache.length > 0) {
    perfTracker.start("wordFilter");
    perfTracker.update("filtering.wordFilter.calls", 1);

    if (DEBUG.wordFilterVerbose) {
      console.log("[MDM WordFilter] Testing filters:", {
        totalFilters: excludeWordCache.length,
        sampleFilters: excludeWordCache.slice(0, 5).map(e => `"${e.original}" (${e.type})`).join(", ") + "..."
      });
    }

    let matched = false;
    let matchedFilter = null;
    for (const entry of excludeWordCache) {
      if (entry.matcher(normalizedTitle)) {
        matched = true;
        matchedFilter = entry;
        perfTracker.update("filtering.wordFilter.hits", 1);
        perfTracker.currentBatch.filtering.wordMatches++;

        // DEBUG: Match gefunden
        if (DEBUG.wordFilter) {
          console.log("[MDM WordFilter] ✂️ MATCH - Deal HIDDEN:", {
            dealId: article.id,
            title: rawTitle,
            filter: entry.original,
            type: entry.type
          });
        }
        break;
      }
    }

    const duration = perfTracker.end("wordFilter");
    perfTracker.update("filtering.wordFilter.totalTime", duration);

    if (matched) return { shouldExclude: true, matchedWord: matchedFilter.original };
  }

  return { shouldExclude: false, matchedWord: null };
}

