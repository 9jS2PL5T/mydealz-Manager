//#region --- 7b. Detail-Seite Highlighting ---
// ===== Badge für gefilterte Deals auf Detail-Seiten =====

function checkAndHighlightFilteredDealOnDetailPage() {
  // Nur auf Detail-Seiten ausführen (nicht in Feed-Listen)
  const isDetailPage = !findDealContainer() || window.location.pathname.includes('/deals/');
  if (!isDetailPage) return;

  const titleElement = document.querySelector('h1.thread-title');
  if (!titleElement) return;

  const titleSpan = titleElement.querySelector('span');
  if (!titleSpan) return;

  const rawTitle = titleSpan.textContent.trim();
  if (!rawTitle) return;

  // Prüfe ob dieser Titel durch die Filter erfasst werden würde
  const filterReasons = getFilterReasonsForTitle(rawTitle);
  if (filterReasons.length === 0) return;

  // Erstelle Badge mit Tooltip
  const badge = document.createElement('span');
  badge.style.cssText = `
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: 8px;
    padding: 2px 8px;
    background: #ff9800;
    color: white;
    border-radius: 12px;
    font-size: 11px;
    font-weight: bold;
    cursor: help;
    user-select: none;
    position: relative;
    vertical-align: baseline;
    transform: translateY(-2px);
  `;

  badge.innerHTML = '⚠️ Gefiltert';

  // Tooltip mit Gründen
  const tooltipText = filterReasons.join('\n');
  badge.setAttribute('title', tooltipText);

  // Für Mobile: Besseres Hover-Verhalten
  badge.addEventListener('click', (e) => {
    if (IS_TOUCH_DEVICE) {
      e.stopPropagation();
      // Zeige Alert statt Tooltip auf Mobile
      alert('Dieser Deal wird in der Übersicht ausgeblendet:\n\n' + tooltipText);
    }
  });

  // Badge zum Titel hinzufügen
  titleSpan.parentElement.appendChild(badge);
}

function getFilterReasonsForTitle(rawTitle) {
  const reasons = [];
  const normalizedTitle = normalizeForSearch(rawTitle);

  // Wortfilter-Gründe
  for (const entry of excludeWordCache) {
    if (entry.matcher(normalizedTitle)) {
      if (entry.type === 'simple') {
        reasons.push(`Wort gefiltert: "${entry.original}"`);
      } else if (entry.type === 'phrase') {
        reasons.push(`Phrase gefiltert: "${entry.original}"`);
      } else if (entry.type === 'wildcard') {
        reasons.push(`Wildcard gefiltert: "${entry.original}"`);
      } else if (entry.type === 'and') {
        reasons.push(`UND-Filter: "${entry.original}"`);
      } else if (entry.type === 'negation-or') {
        reasons.push(`Negation-Filter: "${entry.original}"`);
      } else if (entry.type === 'negation-and') {
        reasons.push(`Negation-UND-Filter: "${entry.original}"`);
      }
      // Zeige max 3 Gründe
      if (reasons.length >= 3) break;
    }
  }

  // Preis-Filter-Grund (aus separatem Preis-Element auf Detail-Seite)
  if (maxPrice > 0 && reasons.length < 3) {
    const priceElement = document.querySelector(".thread-price");
    if (priceElement) {
      const priceText = priceElement.textContent.trim();
      const euroFormatMatch = priceText.match(/([\d.,]+)\s*€/);
      if (euroFormatMatch) {
        const priceStr = euroFormatMatch[1];
        const extractedPrice = parseFloat(
          priceStr.replace('.', '').replace(',', '.')
        );
        if (!isNaN(extractedPrice) && extractedPrice > maxPrice) {
          reasons.push(`Preis zu hoch: ${extractedPrice}€ > ${maxPrice}€`);
        }
      }
    }
  }

  // Händler-Filter-Grund
  if (reasons.length < 3) {
    const merchantLink = document.querySelector('a[data-t="merchantLink"]');
    if (merchantLink) {
      const merchantName = merchantLink.textContent.trim();
      const normalizedMerchantName = normalizeForSearch(merchantName);

      // Prüfe Händler-ID und Händler-Name gegen Filter
      if (excludeMerchantsCache.normalizedNames.has(normalizedMerchantName)) {
        reasons.push(`Händler gefiltert: "${merchantName}"`);
      }
    }
  }

  // Kalte Deals
  if (hideColdDeals && reasons.length < 3) {
    const article = document.querySelector('article[data-t="thread"]');
    if (article) {
      const tempElement = article.querySelector('.vote-temp');
      const tempText = tempElement?.textContent?.trim();
      if (tempText && tempText.includes('°')) {
        const temp = parseInt(tempText);
        if (temp < 0) {
          reasons.push(`Deal zu kalt: ${temp}°`);
        }
      }
    }
  }

  return reasons;
}

