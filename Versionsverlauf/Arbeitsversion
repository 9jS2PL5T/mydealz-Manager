// Deal ausblenden
function hideDeal(deal, reason = "unknown") {
  if (!deal) return;

  clearTemperatureOverrideVisuals(deal);

  const dealId = deal.getAttribute("id") || "unknown";
  const wasAlreadyHidden = deal.classList.contains("mydealz-manager-hidden");

  deal.classList.add("mydealz-manager-hidden");
  deal.style.setProperty("display", "none", "important");
  deal.setAttribute("data-hidden-by-mydealz-manager", "true");
  deal.setAttribute("data-hide-reason", reason); // Grund speichern

  // Entferne Hide-Button wenn der Deal ausgeblendet wird (Fix für Smartphone-Bug)
  const hideButtonContainer = deal.querySelector(".custom-hide-button");
  if (hideButtonContainer) {
    hideButtonContainer.parentElement?.removeChild(hideButtonContainer);
  }

  if (DEBUG.wordFilter && !wasAlreadyHidden) {
    // Überprüfe ob das Verstecken tatsächlich funktioniert hat
    const computedStyle = window.getComputedStyle(deal);
    const isActuallyHidden = computedStyle.display === "none";

    console.log(`[${getDebugTimestamp()}] [MDM Hide] ✂️ Deal wird VERSTECKT:`, {
      dealId,
      reason,
      wasAlreadyHidden,
      inlineStyle: deal.style.display,
      computedDisplay: computedStyle.display,
      isActuallyHidden,
      hasClass: deal.classList.contains("mydealz-manager-hidden"),
      hasAttribute: deal.getAttribute("data-hidden-by-mydealz-manager")
    });

    // Warnung wenn Deal NICHT versteckt ist trotz Aufruf
    if (!isActuallyHidden) {
      console.warn(`[${getDebugTimestamp()}] [MDM Hide] ⚠️ WARNUNG: Deal wurde NICHT versteckt trotz hideDeal():`, {
        dealId,
        reason,
        inlineStyle: deal.style.display,
        computedDisplay: computedStyle.display,
        allClasses: Array.from(deal.classList),
        possibleCSSConflict: true
      });
    }
  }

  perfTracker.update("domUpdates.hideActions", 1);
  perfTracker.currentBatch.domUpdates.hidden++;
}

function showDeal(deal, reason = "unknown") {
  if (!deal) return;

  const dealId = deal.getAttribute("id") || "unknown";
  const wasHidden = deal.classList.contains("mydealz-manager-hidden");

  deal.classList.remove("mydealz-manager-hidden");
  deal.style.removeProperty("display");
  deal.style.opacity = "";
  deal.setAttribute("data-hidden-by-mydealz-manager", "false");

  if (!String(reason).startsWith("temperature-override:")) {
    clearTemperatureOverrideVisuals(deal);
  }

  if (DEBUG.wordFilter && wasHidden) {
    console.log(`[${getDebugTimestamp()}] [MDM Show] 👁️ Deal wird ANGEZEIGT:`, {
      dealId,
      reason,
      wasHidden,
      displayStyle: deal.style.display
    });
  }

  perfTracker.update("domUpdates.showActions", 1);
  perfTracker.currentBatch.domUpdates.shown++;
}

// Funktion zum Speichern der Sucheinstellungen
function processSucheinstellungen() {
  if (DEBUG.rememberSort) {
    console.log('[MDM RememberSort] processSucheinstellungen() aufgerufen', {
      rememberSort: window.rememberSort,
      pathname: window.location.pathname,
      search: window.location.search,
      isSearchPage: window.location.pathname.includes('/search')
    });
  }

  // Wenn Feature deaktiviert ist, lösche gespeicherte Einstellungen
  if (!window.rememberSort) {
    if (DEBUG.rememberSort) {
      console.log('[MDM RememberSort] Feature deaktiviert, lösche gespeicherte Werte');
    }
    // Prüfen und entfernen der gespeicherten Einstellungen
    if (GM_getValue(PREFERRED_SORT_KEY, null)) {
      GM_deleteValue(PREFERRED_SORT_KEY);
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] PREFERRED_SORT_KEY gelöscht');
      }
    }
    if (GM_getValue(PREFERRED_TIMEFRAME_KEY, null)) {
      GM_deleteValue(PREFERRED_TIMEFRAME_KEY);
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] PREFERRED_TIMEFRAME_KEY gelöscht');
      }
    }
    return;
  }

  // Prüfen, ob wir auf einer Suchseite sind
  if (window.location.pathname.includes("/search")) {
    if (DEBUG.rememberSort) {
      console.log('[MDM RememberSort] Auf Suchseite erkannt');
    }
    // Parameter aus URL auslesen
    const params = new URLSearchParams(window.location.search);
    const currentSort = params.get("sortBy");
    const currentTimeframe = params.get("time_frame");

    // Wenn Sortierung vorhanden ist, speichern
    if (currentSort) {
      GM_setValue(PREFERRED_SORT_KEY, currentSort);
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] Sortierung gespeichert:', currentSort);
      }
    }

    // Wenn Zeitraum vorhanden ist, speichern
    if (currentTimeframe) {
      GM_setValue(PREFERRED_TIMEFRAME_KEY, currentTimeframe);
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] Zeitrahmen gespeichert:', currentTimeframe);
      }
    }

    // Wenn keine Sortierung/Zeitraum gesetzt ist, aber gespeicherte Einstellungen existieren
    const savedSort = GM_getValue(PREFERRED_SORT_KEY, null);
    const savedTimeframe = GM_getValue(PREFERRED_TIMEFRAME_KEY, null);

    if (DEBUG.rememberSort) {
      console.log('[MDM RememberSort] Gespeicherte Werte:', { savedSort, savedTimeframe });
      console.log('[MDM RememberSort] URL-Parameter:', {
        hasSortBy: params.has('sortBy'),
        hasTimeFrame: params.has('time_frame'),
        currentSort,
        currentTimeframe
      });
    }

    // NUR redirecten wenn BEIDE Parameter fehlen (frische Suche vom Formular)
    // Wenn nur einer fehlt, hat der User ihn bewusst entfernt
    if (
      (savedSort || savedTimeframe) &&
      !params.has("sortBy") &&
      !params.has("time_frame")
    ) {
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] Redirect notwendig - füge gespeicherte Parameter hinzu');
      }
      // Neue URL mit den gespeicherten Einstellungen erstellen
      let newUrl = window.location.href;
      const separator = newUrl.includes("?") ? "&" : "?";
      const additionalParams = [];

      if (savedSort) {
        additionalParams.push("sortBy=" + savedSort);
      }

      if (savedTimeframe) {
        additionalParams.push("time_frame=" + savedTimeframe);
      }

      if (additionalParams.length > 0) {
        newUrl += separator + additionalParams.join("&");
        if (DEBUG.rememberSort) {
          console.log('[MDM RememberSort] Redirecting zu:', newUrl);
        }
        window.location.href = newUrl;
      }
    } else {
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] Kein Redirect notwendig');
      }
    }
  }

  // Suchformulare-Setup aufrufen
  setupSearchFormHandlers();
}

// Separate Funktion für Suchformular-Setup (kann wiederholt aufgerufen werden)
function setupSearchFormHandlers() {
  const searchForms = document.querySelectorAll('form[action*="/search"]');
  if (DEBUG.rememberSort) {
    console.log('[MDM RememberSort] setupSearchFormHandlers: Gefundene Suchformulare:', searchForms.length);
  }

  searchForms.forEach((form) => {
    // Prüfen, ob das Formular bereits verarbeitet wurde
    if (form.dataset.sortingModified === "true") {
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] Formular bereits markiert, überspringe:', form);
      }
      return;
    }

    // Markieren, dass das Formular verarbeitet wurde
    form.dataset.sortingModified = "true";
    if (DEBUG.rememberSort) {
      console.log('[MDM RememberSort] ✅ Neues Formular gefunden und markiert:', form, {
        action: form.action,
        method: form.method
      });
    }

    // Event-Listener für das Absenden des Formulars hinzufügen
    form.addEventListener("submit", function (e) {
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] 📤 Formular wird abgesendet', {
          rememberSort: window.rememberSort,
          formAction: form.action,
          formData: new FormData(form)
        });
      }

      // Nur fortfahren, wenn Feature aktiviert ist
      if (!window.rememberSort) {
        if (DEBUG.rememberSort) {
          console.log('[MDM RememberSort] Feature deaktiviert, keine Parameter hinzugefügt');
        }
        return;
      }

      const savedSort = GM_getValue(PREFERRED_SORT_KEY, null);
      const savedTimeframe = GM_getValue(PREFERRED_TIMEFRAME_KEY, null);
      if (DEBUG.rememberSort) {
        console.log('[MDM RememberSort] 💾 Gespeicherte Werte werden hinzugefügt:', { savedSort, savedTimeframe });
      }

      if (savedSort || savedTimeframe) {
        // Sortierung hinzufügen
        if (savedSort) {
          let sortByInput = form.querySelector('input[name="sortBy"]');
          if (!sortByInput) {
            sortByInput = document.createElement("input");
            sortByInput.type = "hidden";
            sortByInput.name = "sortBy";
            form.appendChild(sortByInput);
            if (DEBUG.rememberSort) {
              console.log('[MDM RememberSort] Hidden input für sortBy erstellt');
            }
          }
          sortByInput.value = savedSort;
          if (DEBUG.rememberSort) {
            console.log('[MDM RememberSort] sortBy gesetzt auf:', savedSort);
          }
        }

        // Zeitraum hinzufügen
        if (savedTimeframe) {
          let timeframeInput = form.querySelector('input[name="time_frame"]');
          if (!timeframeInput) {
            timeframeInput = document.createElement("input");
            timeframeInput.type = "hidden";
            timeframeInput.name = "time_frame";
            form.appendChild(timeframeInput);
            if (DEBUG.rememberSort) {
              console.log('[MDM RememberSort] Hidden input für time_frame erstellt');
            }
          }
          timeframeInput.value = savedTimeframe;
          if (DEBUG.rememberSort) {
            console.log('[MDM RememberSort] time_frame gesetzt auf:', savedTimeframe);
          }
        }

        if (DEBUG.rememberSort) {
          console.log('[MDM RememberSort] ✅ Alle Parameter hinzugefügt, Formular wird nun abgesendet');
        }
      }
    });
  });
}

// Funktion zum Ausblenden von User-Deals
async function handleUserBlock(article, options = {}) {
  const { fallbackUsername = null } = options;

  if (DEBUG.userBlocking) {
    console.log("[MDM UserBlock] handleUserBlock called", {
      article: article?.id,
      fallbackUsername,
    });
  }

  const userInfo = extractDealUsername(article, {
    context: `handleUserBlock:${article?.id || "unknown"}`,
    debug: true,
  });

  let displayName = userInfo.displayName;
  let foundVia = userInfo.foundVia;

  if (!displayName && fallbackUsername) {
    displayName = fallbackUsername;
    foundVia = "button-label-fallback";
    console.warn("[MDM UserBlock] Using fallback username from button label", {
      articleId: article?.id,
      fallbackUsername,
    });
  }

  if (!displayName) {
    console.error(
      "[MDM Critical] ❌ ALLE Selektoren fehlgeschlagen! Kann Username nicht finden."
    );
    console.error("[MDM Critical] Article ID:", article.id);
    console.error(
      "[MDM Critical] Article HTML (first 500 chars):",
      article.innerHTML.substring(0, 500)
    );
    if (DEBUG.userBlocking) {
      console.log("[MDM UserBlock] Article attributes:", {
        id: article.id,
        "data-md-author": article.getAttribute("data-md-author"),
        "data-md-state": article.getAttribute("data-md-state"),
        fallbackUsername,
      });
    }
    alert("Benutzerinformation konnte nicht gefunden werden.");
    return;
  }

  // Normalisiere für Vergleich/Speicher-Key
  const normalizedUsername = displayName.toLowerCase();

  console.log('[MDM UserBlock] Username normalized:', {
    displayName,
    normalizedUsername,
    foundVia,
  });

  // Bestätigungsdialog mit optionalem "Nicht mehr anzeigen"
  console.log('[MDM UserBlock] Showing confirm dialog for:', displayName);
  const userConfirmed = await confirmBlockAction(
    `Möchtest du wirklich alle Deals von "${displayName}" ausblenden?`
  );
  console.log('[MDM UserBlock] User confirmed:', userConfirmed);

  if (!userConfirmed) {
    console.log("[MDM UserBlock] User cancelled blocking");
    return;
  }

  // Lade blockierte Benutzer (Object-Format)
  const blockedUsers = GM_getValue("blockedUsers", {});
  console.log("[MDM UserBlock] Current blocked users:", blockedUsers);

  // Prüfe ob User bereits blockiert (case-insensitive)
  if (!blockedUsers[normalizedUsername]) {
    console.log("[MDM UserBlock] User NOT in blocklist, adding now:", normalizedUsername);

    // Speichere mit displayName + normalizedUsername
    blockedUsers[normalizedUsername] = {
      displayName: displayName,
      normalizedUsername: normalizedUsername,
      timestamp: Date.now()
    };

    if (DEBUG.userBlocking) {
      console.log("[MDM UserBlock] Saving blockedUsers:", blockedUsers);
    }

    // Sofort speichern
    GM_setValue("blockedUsers", blockedUsers);

    if (DEBUG.userBlocking) {
      console.log("[MDM UserBlock] blockedUsers saved to GM storage");
    }

    // Timestamp für UI
    userAddedAt[normalizedUsername] = { timestamp: formatTimestamp(), isLegacy: false };
    GM_setValue("userAddedAt", userAddedAt);

    if (DEBUG.userBlocking) {
      console.log("[MDM UserBlock] User added to blocklist successfully:", normalizedUsername);
    }
  } else {
    if (DEBUG.userBlocking) {
      console.log("[MDM UserBlock] User ALREADY in blocklist:", normalizedUsername);
    }
  }

  // Sofort Filter anwenden (forceRun=true um Early Exit zu überspringen)
  if (DEBUG.userBlocking) {
    console.log('[MDM UserBlock] Calling processArticles(), blocked users:', Object.keys(blockedUsers));
  }
  processArticles(true);
}

